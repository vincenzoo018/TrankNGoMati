@model TrackNGoMati.Models.Document
@{
    ViewData["Title"] = "Document Details";
}

<!-- Page Header -->
<div class="page-header animate-fade-in" style="align-items:center; margin-bottom: 24px; border-bottom: 1px solid var(--border); padding-bottom: 16px; display: flex; justify-content: space-between;">
    <div class="page-header-left">
        <h1 class="page-title" style="font-size: 24px;">@Model.TrackingNumber</h1>
        <p class="page-subtitle" style="font-size: 14px;">@Model.Title — @Model.SubmittedBy</p>
    </div>
    <div class="page-header-right">
        <a href="/Admin/Document" class="btn btn-secondary" style="padding: 8px 16px; border-color:var(--border);">
            <i data-lucide="arrow-left"></i> Back to List
        </a>
    </div>
</div>

<!-- Stepper -->
<div class="animate-fade-in" style="display: flex; justify-content: center; align-items: center; margin-bottom: 32px; padding: 0 40px;">
    @for (int i = 1; i <= Model.TotalSteps; i++)
    {
        var label = i switch { 1 => "Submitted", 2 => "Endorsed", 3 => "Accepted", 4 => "Reviewed", 5 => "Approved", 6 => "Completed", _ => $"Step {i}" };
        
        <div style="display: flex; flex-direction: column; align-items: center; position: relative; z-index: 1;">
            @if (i < Model.CurrentStepIndex) {
                <div style="width: 32px; height: 32px; border-radius: 50%; background-color: var(--brand); color: white; display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 14px;">@i</div>
                <div style="margin-top: 8px; font-size: 11px; font-weight: 600; color: var(--ink);">@label</div>
            } else if (i == Model.CurrentStepIndex) {
                <div style="width: 32px; height: 32px; border-radius: 50%; background-color: white; border: 2px solid var(--brand); color: var(--brand); display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 14px;">@i</div>
                <div style="margin-top: 8px; font-size: 11px; font-weight: 600; color: var(--brand);">@label</div>
            } else {
                <div style="width: 32px; height: 32px; border-radius: 50%; background-color: white; border: 1px solid var(--border); color: var(--ink-muted); display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 14px;">@i</div>
                <div style="margin-top: 8px; font-size: 11px; font-weight: 500; color: var(--ink-muted);">@label</div>
            }
        </div>
        
        @if (i < Model.TotalSteps)
        {
            <div style="flex: 1; height: 1px; background-color: @(i < Model.CurrentStepIndex ? "var(--brand)" : "var(--border)"); margin: 0 16px; margin-bottom: 20px;"></div>
        }
    }
</div>

<div class="animate-fade-in" style="display: flex; gap: 24px; align-items: flex-start;">
    <!-- LEFT COLUMN: Preview & Info -->
    <div style="flex: 2; display: flex; flex-direction: column; gap: 24px;">
        
        <!-- Document Preview Panel -->
        <div class="card" style="margin: 0; border-radius: 8px;">
            <div class="card-header" style="border-bottom: 1px solid var(--border); padding: 16px 24px; display: flex; justify-content: space-between; align-items: center;">
                <h3 style="margin: 0; font-size: 16px; font-weight: 600; color: var(--ink);"><i data-lucide="eye" style="width: 16px; height: 16px; display:inline-block; vertical-align:middle; margin-right:6px;"></i> Document Preview</h3>
                <a href="@Model.AttachmentPath" target="_blank" class="btn btn-secondary" style="padding: 4px 12px; font-size: 12px;">Open in New Tab</a>
            </div>
            <div class="card-body" style="padding: 0; background: #e5e7eb; display: flex; justify-content: center; align-items: center; min-height: 700px; overflow: hidden; border-bottom-left-radius: 8px; border-bottom-right-radius: 8px;">
                @if (!string.IsNullOrEmpty(Model.AttachmentPath))
                {
                    if (Model.AttachmentPath.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
                    {
                        <iframe src="@Model.AttachmentPath" style="width: 100%; height: 700px; border: none;"></iframe>
                    }
                    else
                    {
                        <img src="@Model.AttachmentPath" style="max-width: 100%; max-height: 700px; object-fit: contain;" />
                    }
                }
                else
                {
                    <div style="color: var(--ink-muted); text-align: center; padding: 40px;">
                        <i data-lucide="file-image" style="width: 48px; height: 48px; margin-bottom: 16px; opacity: 0.5;"></i>
                        <p>No document attachment available.</p>
                    </div>
                }
            </div>
        </div>

        <!-- Document Information -->
        <div class="card" style="margin: 0; border-radius: 8px;">
            <div class="card-header" style="border-bottom: 1px solid var(--border); padding: 16px 24px;">
                <h3 style="margin: 0; font-size: 16px; font-weight: 600; color: var(--ink);">Document Metadata</h3>
            </div>
            <div class="card-body" style="padding: 24px;">
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
                    <div style="display: flex; flex-direction: column; gap: 16px;">
                        <div>
                            <div style="font-size: 10px; font-weight: 600; color: var(--ink-muted); text-transform: uppercase;">Tracking Number</div>
                            <div style="font-size: 14px; color: var(--ink); font-weight: 500;">@Model.TrackingNumber</div>
                        </div>
                        <div>
                            <div style="font-size: 10px; font-weight: 600; color: var(--ink-muted); text-transform: uppercase;">Sender / Submitted By</div>
                            <div style="font-size: 14px; color: var(--ink);">@Model.SubmittedBy</div>
                        </div>
                        <div>
                            <div style="font-size: 10px; font-weight: 600; color: var(--ink-muted); text-transform: uppercase;">Contact Number</div>
                            <div style="font-size: 14px; color: var(--ink);">@Model.ContactNumber</div>
                        </div>
                    </div>
                    <div style="display: flex; flex-direction: column; gap: 16px;">
                        <div>
                            <div style="font-size: 10px; font-weight: 600; color: var(--ink-muted); text-transform: uppercase;">Department</div>
                            <div style="font-size: 14px; color: var(--ink);">@(Model.OriginatingDepartment ?? "N/A")</div>
                        </div>
                        <div>
                            <div style="font-size: 10px; font-weight: 600; color: var(--ink-muted); text-transform: uppercase;">Date Filed</div>
                            <div style="font-size: 14px; color: var(--ink);">@Model.DateFiled.ToString("MMM dd, yyyy - hh:mm tt")</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- RIGHT COLUMN: Actions, Comments, Tracer -->
    <div style="flex: 1; display: flex; flex-direction: column; gap: 24px;">
        
        <!-- Actions Panel -->
        <div class="card" style="margin: 0; border-radius: 8px;">
            <div class="card-header" style="border-bottom: 1px solid var(--border); padding: 16px 24px; background: #f8fafc; border-top-left-radius: 8px; border-top-right-radius: 8px;">
                <h3 style="margin: 0; font-size: 16px; font-weight: 600; color: var(--ink);"><i data-lucide="zap" style="width: 16px; height: 16px; display:inline-block; vertical-align:middle; margin-right:6px; color: #F59E0B;"></i> Actions</h3>
            </div>
            <div class="card-body" style="padding: 16px 24px; display: flex; flex-direction: column; gap: 12px;">
                <div style="font-size: 12px; color: var(--ink-muted); text-align: center;">No administrative workflow actions available.</div>
                <div style="display: flex; gap: 12px; margin-top: 8px;">
                    <button class="btn btn-secondary" onclick="window.print()" style="flex: 1; justify-content: center;">
                        <i data-lucide="printer"></i> Print
                    </button>
                    <button class="btn btn-secondary" style="flex: 1; justify-content: center;">
                        <i data-lucide="download"></i> Export
                    </button>
                </div>
            </div>
        </div>

        <!-- Comments -->
        <div class="card" style="margin: 0; border-radius: 8px;">
            <div class="card-header" style="border-bottom: 1px solid var(--border); padding: 16px 24px;">
                <h3 style="margin: 0; font-size: 14px; font-weight: 600; color: var(--ink);">Leave a Comment</h3>
            </div>
            <div class="card-body" style="padding: 16px 24px;">
                <textarea id="commentBox" class="form-control" rows="3" placeholder="Add remarks, marginal notes, or instructions before proceeding..." style="width: 100%; margin-bottom: 12px; resize: vertical; border-radius: 6px;"></textarea>
                <button class="btn btn-secondary" onclick="postComment()" style="width: 100%; justify-content: center;">
                    <i data-lucide="message-square"></i> Post Comment
                </button>
            </div>
        </div>

        <!-- Document Tracer -->
        <div class="card" style="margin: 0; border-radius: 8px;">
            <div class="card-header" style="border-bottom: 1px solid var(--border); padding: 16px 24px; display: flex; align-items: center; gap: 8px;">
                <i data-lucide="activity" style="width: 18px; height: 18px; color: var(--ink);"></i>
                <h3 style="margin: 0; font-size: 16px; font-weight: 600; color: var(--ink);">Audit Trail</h3>
            </div>
            <div class="card-body" style="padding: 24px;">
                <div style="position: relative; padding-left: 20px;">
                    <!-- Line -->
                    <div style="position: absolute; left: 15px; top: 16px; bottom: 0; width: 2px; background: var(--border);"></div>

                    @if (Model.AuditTrailEntries != null && Model.AuditTrailEntries.Any())
                    {
                        @foreach (var entry in Model.AuditTrailEntries.OrderByDescending(a => a.Timestamp))
                        {
                            var initial = entry.User?.FullName != null && entry.User.FullName.Length >= 2 
                                ? entry.User.FullName.Substring(0, 2).ToUpper() 
                                : "SYS";
                            <div style="position: relative; padding-bottom: 24px; padding-left: 24px;">
                                <div style="position: absolute; left: -16px; top: 0; width: 24px; height: 24px; border-radius: 50%; background: var(--brand); color: white; display: flex; justify-content: center; align-items: center; font-size: 10px; font-weight: 700; border: 4px solid white; box-sizing: content-box;">@initial</div>
                                <div style="font-weight: 600; font-size: 13px; color: var(--ink);">@entry.Action</div>
                                <div style="font-size: 12px; color: var(--ink-muted); margin-top: 4px;">@entry.Details</div>
                                <div style="font-size: 11px; color: var(--ink-muted); margin-top: 4px;">@entry.Timestamp.ToString("MMM dd, yyyy \u2014 h:mm tt")</div>
                            </div>
                        }
                    }
                    else
                    {
                        <div style="font-size: 12px; color: var(--ink-muted); padding-left: 24px;">No tracking history yet.</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>



@section Scripts {
    <script>
        function postComment() {
            var comment = document.getElementById('commentBox').value;
            if(!comment) return;
            // TODO: AJAX to save comment
            showToast('Comment added successfully!', 'success');
            document.getElementById('commentBox').value = '';
            // In a real implementation, we would prepend the comment to the tracer
        }

    </script>
}
