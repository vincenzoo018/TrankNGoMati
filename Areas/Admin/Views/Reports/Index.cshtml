@{
    ViewData["Title"] = "System Reports";
}

<div class="page-header animate-fade-in">
    <div class="page-header-left">
        <h1 class="page-title">System Reports</h1>
        <p class="page-subtitle">Generate and export system-wide performance and compliance reports</p>
    </div>
</div>

<div class="card animate-fade-in" style="max-width: 600px; margin: 0 auto; margin-top: 40px;" id="passwordGate">
    <div class="card-header">
        <span class="card-header-title"><i data-lucide="lock"></i> Password Protected Area</span>
    </div>
    <div class="card-body" style="text-align: center;">
        <p style="margin-bottom: 16px;">This module contains sensitive system data. Please verify your identity.</p>
        <div class="form-group" style="text-align: left;">
            <label class="form-label">Admin Password</label>
            <input type="password" id="reportPassword" class="form-control" placeholder="Enter password (demo: password123)" />
        </div>
        <button class="btn btn-primary" onclick="verifyPassword()" style="width: 100%; justify-content: center;">
            <i data-lucide="unlock"></i> Unlock Reports
        </button>
    </div>
</div>

<div id="reportsContent" style="display: none;" class="animate-fade-in">
    <div class="grid" style="grid-template-columns: repeat(2, 1fr); gap: 24px;">
        <div class="card">
            <div class="card-header"><span class="card-header-title">Document Summary Report</span></div>
            <div class="card-body">
                <p class="text-meta" style="margin-bottom:16px;">Export total documents processed by type and status.</p>
                <button class="btn btn-primary" onclick="generateReport('Document Summary')"><i data-lucide="download"></i> Export CSV</button>
            </div>
        </div>
        <div class="card">
            <div class="card-header"><span class="card-header-title">Department Performance</span></div>
            <div class="card-body">
                <p class="text-meta" style="margin-bottom:16px;">Export processing times and FSM bottleneck analysis.</p>
                <button class="btn btn-primary" onclick="generateReport('Department Performance')"><i data-lucide="download"></i> Export CSV</button>
            </div>
        </div>
        <div class="card">
            <div class="card-header"><span class="card-header-title">Audit Trail Export</span></div>
            <div class="card-body">
                <p class="text-meta" style="margin-bottom:16px;">Export complete system logs for compliance.</p>
                <button class="btn btn-primary" onclick="generateReport('Audit Logs')"><i data-lucide="download"></i> Export CSV</button>
            </div>
        </div>
        <div class="card">
            <div class="card-header"><span class="card-header-title">ARTA Escalation Report</span></div>
            <div class="card-body">
                <p class="text-meta" style="margin-bottom:16px;">Export RA 11032 compliance violations and escalations.</p>
                <button class="btn btn-primary" onclick="generateReport('ARTA Escalations')"><i data-lucide="download"></i> Export CSV</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function verifyPassword() {
            var pwd = document.getElementById('reportPassword').value;
            if (pwd === "password123") {
                document.getElementById('passwordGate').style.display = 'none';
                document.getElementById('reportsContent').style.display = 'block';
                showToast('Access Granted', 'success');
            } else {
                showToast('Incorrect Password', 'error');
            }
        }
    </script>
}
