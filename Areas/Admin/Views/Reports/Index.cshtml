@model IEnumerable<TrackNGoMati.Models.ReportLog>
@{
    ViewData["Title"] = "Reports";
}

<div class="page-header animate-fade-in" style="margin-bottom: 24px;">
    <div class="page-header-left">
        <h1 class="page-title">Generated Reports</h1>
        <p class="page-subtitle">View history of system reports and generated analytics</p>
    </div>
    <div class="page-header-right">
        <button class="btn btn-primary"><i data-lucide="plus"></i> Generate New Report</button>
    </div>
</div>

<div class="card animate-fade-in" style="border-radius: 8px;">
    <div style="padding: 16px; border-bottom: 1px solid var(--border);">
        <div class="search-input" style="width: 100%;">
            <i data-lucide="search"></i>
            <input type="text" placeholder="Search reports..." style="padding-left: 36px; height: 40px;" />
        </div>
    </div>
    
    <div class="table-wrapper" style="border:none;">
        <table>
            <thead>
                <tr>
                    <th style="padding-left: 20px;">REPORT TYPE</th>
                    <th>GENERATED BY</th>
                    <th>DATE RANGE COVERED</th>
                    <th>GENERATED AT</th>
                    <th>ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td style="padding-left: 20px; font-weight:600; color:var(--ink);">
                            <i data-lucide="file-bar-chart" style="width:16px; height:16px; display:inline-block; vertical-align:middle; margin-right:8px; color:var(--brand);"></i>
                            @r.ReportType
                        </td>
                        <td>@r.GeneratedByUser?.FullName</td>
                        <td>
                            @if(r.DateFrom != default(DateTime) && r.DateTo != default(DateTime)) {
                                <span>@r.DateFrom.ToString("MMM dd, yyyy") &mdash; @r.DateTo.ToString("MMM dd, yyyy")</span>
                            } else {
                                <span style="color:var(--ink-muted);">N/A</span>
                            }
                        </td>
                        <td>@r.GeneratedAt.ToString("MMM dd, yyyy HH:mm")</td>
                        <td>
                            <button class="btn btn-ghost" style="color:var(--brand);"><i data-lucide="download"></i> Download PDF</button>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="5" style="text-align:center; padding:40px; color:var(--ink-muted);">No reports generated yet.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
