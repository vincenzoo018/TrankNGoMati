@{
    ViewData["Title"] = "System Analytics & Reports";
    var exportError = TempData["ExportError"] as string;
    
    // Extract ViewBag data
    var slaBreached = ViewBag.SlaBreached ?? 0;
    var slaWithinLimit = ViewBag.SlaWithinLimit ?? 0;
    
    var pending = ViewBag.StatusPending ?? 0;
    var inProgress = ViewBag.StatusInProgress ?? 0;
    var completed = ViewBag.StatusCompleted ?? 0;
}

<div class="page-header animate-fade-in" style="margin-bottom: 24px;">
    <div class="page-header-left">
        <h1 class="page-title">System Analytics & Reports</h1>
        <p class="page-subtitle">Track document turnaround times, SLA compliance, and bottlenecks</p>
    </div>
</div>

@if (exportError != null)
{
    <div style="background:#FEF2F2; border:1px solid var(--destructive); border-radius:4px; padding:12px 16px; margin-bottom:16px; display:flex; align-items:center; gap:8px;">
        <i data-lucide="alert-circle" style="width:16px;height:16px;color:var(--destructive);flex-shrink:0;"></i>
        <span style="font-size:var(--fs-body); color:var(--destructive);">@exportError</span>
    </div>
}

<div style="background:var(--brand-soft); border:1px solid var(--brand); border-radius:6px; padding:14px 18px; margin-bottom:24px; display:flex; align-items:center; gap:10px;">
    <i data-lucide="lock" style="width:18px;height:18px;color:var(--brand);flex-shrink:0;"></i>
    <div>
        <strong style="color:var(--brand); font-size:var(--fs-body);">Password-Gated Exports</strong>
        <p class="text-meta" style="margin-top:2px;">All data exports require your secondary export password to prevent unauthorized data extraction.</p>
    </div>
</div>

<!-- Charts Grid -->
<div class="grid animate-fade-in" style="grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap:20px; margin-bottom: 24px;">
    
    <!-- SLA Compliance -->
    <div class="card">
        <div class="card-header">
            <span class="card-header-title">SLA Compliance (ARTA)</span>
        </div>
        <div class="card-body" style="position: relative; height: 250px;">
            <canvas id="slaChart"></canvas>
        </div>
    </div>

    <!-- Volume by Status -->
    <div class="card">
        <div class="card-header">
            <span class="card-header-title">Document Volume by Status</span>
        </div>
        <div class="card-body" style="position: relative; height: 250px;">
            <canvas id="volumeChart"></canvas>
        </div>
    </div>
    
    <!-- Avg Processing Time -->
    <div class="card" style="grid-column: 1 / -1;">
        <div class="card-header">
            <span class="card-header-title">Average Processing Time by Department (Days)</span>
        </div>
        <div class="card-body" style="position: relative; height: 300px;">
            <canvas id="timeChart"></canvas>
        </div>
    </div>
</div>

<!-- Report Cards Grid (Exports) -->
<h3 style="font-size: 16px; font-weight: 600; color: var(--ink); margin-bottom: 16px; padding-top: 16px; border-top: 1px solid var(--border);">Download Raw Data</h3>
<div class="grid animate-fade-in" style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap:20px; margin-bottom: 32px;">

    <div class="card">
        <div class="card-header">
            <span class="card-header-title">
                <i data-lucide="files" style="width:16px;height:16px;display:inline;vertical-align:middle;margin-right:6px;"></i>
                Document Summary Report
            </span>
        </div>
        <div class="card-body">
            <p class="text-meta" style="margin-bottom:16px;">Export all document records with status, ARTA compliance indicators, and office assignments.</p>
            <button class="btn btn-primary" onclick="openExportModal('documents')">
                <i data-lucide="download"></i> Export CSV
            </button>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <span class="card-header-title">
                <i data-lucide="activity" style="width:16px;height:16px;display:inline;vertical-align:middle;margin-right:6px;"></i>
                Audit Trail Export
            </span>
        </div>
        <div class="card-body">
            <p class="text-meta" style="margin-bottom:16px;">Export the complete, tamper-evident activity log including all user actions and document state changes.</p>
            <button class="btn btn-primary" onclick="openExportModal('audit')">
                <i data-lucide="download"></i> Export CSV
            </button>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <span class="card-header-title">
                <i data-lucide="alert-triangle" style="width:16px;height:16px;display:inline;vertical-align:middle;margin-right:6px;"></i>
                ARTA Escalation Report
            </span>
        </div>
        <div class="card-body">
            <p class="text-meta" style="margin-bottom:16px;">Export RA 11032 compliance violations, escalation details, and resolution status per document.</p>
            <button class="btn btn-primary" onclick="openExportModal('escalations')">
                <i data-lucide="download"></i> Export CSV
            </button>
        </div>
    </div>

</div>

<!-- Password-Gated Export Modal -->
<div class="modal-overlay" id="exportModal">
    <div class="modal animate-fade-in">
        <div class="modal-header">
            <h3 class="modal-title">
                <i data-lucide="lock" style="width:18px;height:18px;display:inline;vertical-align:middle;margin-right:6px;"></i>
                Authorize Export
            </h3>
            <button class="modal-close" onclick="closeModal('exportModal')"><i data-lucide="x"></i></button>
        </div>
        <form method="post" action="/Admin/Reports/ExportCsv">
            <div class="modal-body">
                <input type="hidden" name="exportType" id="export-type-input" />
                <p class="text-meta" style="margin-bottom:16px;">
                    Enter your secondary export password to authorize this data extraction.
                    This action will be logged in the audit trail.
                </p>
                <div class="form-group">
                    <label class="form-label form-label-required">Export Password</label>
                    <input type="password" class="form-control" name="exportPassword" placeholder="Enter export password" required />
                </div>
                <div style="background:#FEF9C3; border:1px solid #CA8A04; border-radius:4px; padding:10px 14px; font-size:12px; color:#92400E; margin-top:12px;">
                    <strong>Default export password:</strong> export@TrackNGo2026
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeModal('exportModal')">Cancel</button>
                <button type="submit" class="btn btn-primary">
                    <i data-lucide="download"></i> Authorize &amp; Export
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openExportModal(type) {
            document.getElementById('export-type-input').value = type;
            openModal('exportModal');
        }

        // Initialize Charts
        document.addEventListener('DOMContentLoaded', function() {
            // 1. SLA Pie Chart
            const slaCtx = document.getElementById('slaChart').getContext('2d');
            new Chart(slaCtx, {
                type: 'doughnut',
                data: {
                    labels: ['Within Limit', 'Breached ARTA'],
                    datasets: [{
                        data: [@slaWithinLimit, @slaBreached],
                        backgroundColor: ['#10B981', '#EF4444'],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { position: 'bottom' } },
                    cutout: '70%'
                }
            });

            // 2. Volume Bar Chart
            const volCtx = document.getElementById('volumeChart').getContext('2d');
            new Chart(volCtx, {
                type: 'bar',
                data: {
                    labels: ['Pending', 'In Progress', 'Completed'],
                    datasets: [{
                        label: 'Documents',
                        data: [@pending, @inProgress, @completed],
                        backgroundColor: ['#F59E0B', '#3B82F6', '#10B981'],
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
                }
            });

            // 3. Dept Processing Time Line/Bar Chart
            const timeCtx = document.getElementById('timeChart').getContext('2d');
            const deptData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ProcessingTimes));
            
            new Chart(timeCtx, {
                type: 'bar',
                data: {
                    labels: deptData.map(d => d.label),
                    datasets: [{
                        label: 'Average Days to Complete',
                        data: deptData.map(d => d.value),
                        backgroundColor: '#6366F1',
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: { y: { beginAtZero: true } }
                }
            });
        });
    </script>
}
