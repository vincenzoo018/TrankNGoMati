<!-- Auto-Route Visualization -->
<div class="card" style="margin-top:24px;">
    <div class="card-header">
        <span class="card-header-title">Auto-Escalation Routing Flow</span>
    </div>
    <div class="card-body">
        <div class="fsm-pipeline">
            <div class="fsm-state">
                <div class="fsm-state-box">
                    <i data-lucide="clock" style="width:16px;height:16px;display:inline;vertical-align:middle;margin-right:4px;"></i>
                    Document Overdue
                </div>
            </div>
            <div class="fsm-arrow done"><i data-lucide="arrow-right"></i></div>
            <div class="fsm-state">
                <div class="fsm-state-box done">
                    <i data-lucide="lock" style="width:16px;height:16px;display:inline;vertical-align:middle;margin-right:4px;"></i>
                    Auto-Lock
                </div>
            </div>
            <div class="fsm-arrow done"><i data-lucide="arrow-right"></i></div>
            <div class="fsm-state">
                <div class="fsm-state-box done">
                    <i data-lucide="bell" style="width:16px;height:16px;display:inline;vertical-align:middle;margin-right:4px;"></i>
                    Notify Oversight
                </div>
            </div>
            <div class="fsm-arrow done"><i data-lucide="arrow-right"></i></div>
            <div class="fsm-state">
                <div class="fsm-state-box active">
                    <i data-lucide="building-2" style="width:16px;height:16px;display:inline;vertical-align:middle;margin-right:4px;"></i>
                    Route to Mayor
                </div>
            </div>
        </div>
    </div>
</div>
