@{
    ViewData["Title"] = "SMS Notifications";
}

<div class="page-header animate-fade-in">
    <div class="page-header-left">
        <h1 class="page-title">SMS Notifications Gateway</h1>
        <p class="page-subtitle">Monitor automated SMS alerts sent to clients and stakeholders for status updates and ARTA delays</p>
    </div>
    <div class="page-header-right">
        <button class="btn btn-primary" onclick="sendSmsReminder()"><i data-lucide="send"></i> Dispatch Manual Reminder</button>
    </div>
</div>

<div class="card animate-fade-in">
    <div class="card-header"><span class="card-header-title">Recent Dispatches (SMS_Notifications Table)</span></div>
    <div class="table-wrapper" style="border:none;">
        <table>
            <thead>
                <tr><th>Date Sent</th><th>Recipient Number</th><th>Linked Document</th><th>Message Preview</th><th>Status</th></tr>
            </thead>
            <tbody>
                <tr>
                    <td>Just now</td>
                    <td style="font-family:monospace;">0918-765-4321</td>
                    <td><a href="#">TNG-2026-0899</a></td>
                    <td style="max-width: 300px; text-overflow: ellipsis; overflow: hidden; white-space: nowrap;">
                        TrackNGo: Your Travel Order is now Approved. Pick up at Mayor's Office.
                    </td>
                    <td><span class="badge badge-completed">Delivered</span></td>
                </tr>
                <tr class="alert-row">
                    <td>1 hour ago</td>
                    <td style="font-family:monospace;">0917-123-4567</td>
                    <td><a href="#">TNG-2026-0004</a></td>
                    <td style="max-width: 300px; text-overflow: ellipsis; overflow: hidden; white-space: nowrap;">
                        ARTA ALERT: Document TNG-2026-0004 has exceeded 20 days. Auto-escalated to Mayor.
                    </td>
                    <td><span class="badge badge-completed">Delivered</span></td>
                </tr>
                <tr>
                    <td>2 hours ago</td>
                    <td style="font-family:monospace;">0919-345-6789</td>
                    <td><a href="#">TNG-2026-0095</a></td>
                    <td style="max-width: 300px; text-overflow: ellipsis; overflow: hidden; white-space: nowrap;">
                        TrackNGo: Your Purchase Request has been returned for corrections.
                    </td>
                    <td><span class="badge badge-pending">Pending</span></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="card animate-fade-in" style="margin-top: 24px;">
    <div class="card-header"><span class="card-header-title">Gateway Connection Log</span></div>
    <div class="card-body">
        <div class="sms-log-box">
            <p>> Gateway connection established: OK</p>
            <p>> Syncing with SMS Provider API...</p>
            <p>> Batch 1204 dispatched successfully at @DateTime.Now.ToString("HH:mm:ss")</p>
            <p>> Pinging status callbacks...</p>
            <p>> Awaiting further events.</p>
        </div>
    </div>
</div>
