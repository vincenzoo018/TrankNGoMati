@{
    ViewData["Title"] = "Reports Dashboard";
    var exportError = TempData["ExportError"] as string;
}

<div class="page-header animate-fade-in">
    <div class="page-header-left">
        <h1 class="page-title">Reports Dashboard</h1>
        <p class="page-subtitle">Generate and export password-protected reports — RA 11032 ARTA compliance monitoring</p>
    </div>
</div>

@if (exportError != null)
{
    <div style="background:#FEF2F2; border:1px solid var(--destructive); border-radius:4px; padding:12px 16px; margin-bottom:16px; display:flex; align-items:center; gap:8px;">
        <i data-lucide="alert-circle" style="width:16px;height:16px;color:var(--destructive);flex-shrink:0;"></i>
        <span style="font-size:var(--fs-body); color:var(--destructive);">@exportError</span>
    </div>
}

<div style="background:var(--brand-soft); border:1px solid var(--brand); border-radius:6px; padding:14px 18px; margin-bottom:24px; display:flex; align-items:center; gap:10px;">
    <i data-lucide="lock" style="width:18px;height:18px;color:var(--brand);flex-shrink:0;"></i>
    <div>
        <strong style="color:var(--brand); font-size:var(--fs-body);">Password-Gated Exports</strong>
        <p class="text-meta" style="margin-top:2px;">All data exports require your secondary export password to prevent unauthorized data extraction.</p>
    </div>
</div>

<!-- Report Cards Grid -->
<div class="grid animate-fade-in" style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap:20px;">

    <div class="card">
        <div class="card-header">
            <span class="card-header-title">
                <i data-lucide="files" style="width:16px;height:16px;display:inline;vertical-align:middle;margin-right:6px;"></i>
                Document Summary Report
            </span>
        </div>
        <div class="card-body">
            <p class="text-meta" style="margin-bottom:16px;">Export all document records with status, ARTA compliance indicators, and office assignments.</p>
            <button class="btn btn-primary" onclick="openExportModal('documents')">
                <i data-lucide="download"></i> Export CSV
            </button>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <span class="card-header-title">
                <i data-lucide="activity" style="width:16px;height:16px;display:inline;vertical-align:middle;margin-right:6px;"></i>
                Audit Trail Export
            </span>
        </div>
        <div class="card-body">
            <p class="text-meta" style="margin-bottom:16px;">Export the complete, tamper-evident activity log including all user actions and document state changes.</p>
            <button class="btn btn-primary" onclick="openExportModal('audit')">
                <i data-lucide="download"></i> Export CSV
            </button>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <span class="card-header-title">
                <i data-lucide="alert-triangle" style="width:16px;height:16px;display:inline;vertical-align:middle;margin-right:6px;"></i>
                ARTA Escalation Report
            </span>
        </div>
        <div class="card-body">
            <p class="text-meta" style="margin-bottom:16px;">Export RA 11032 compliance violations, escalation details, and resolution status per document.</p>
            <button class="btn btn-primary" onclick="openExportModal('escalations')">
                <i data-lucide="download"></i> Export CSV
            </button>
        </div>
    </div>

</div>

<!-- Password-Gated Export Modal -->
<div class="modal-overlay" id="exportModal">
    <div class="modal animate-fade-in">
        <div class="modal-header">
            <h3 class="modal-title">
                <i data-lucide="lock" style="width:18px;height:18px;display:inline;vertical-align:middle;margin-right:6px;"></i>
                Authorize Export
            </h3>
            <button class="modal-close" onclick="closeModal('exportModal')"><i data-lucide="x"></i></button>
        </div>
        <form method="post" action="/Cart/Reports/ExportCsv">
            <div class="modal-body">
                <input type="hidden" name="exportType" id="export-type-input" />
                <p class="text-meta" style="margin-bottom:16px;">
                    Enter your secondary export password to authorize this data extraction.
                    This action will be logged in the audit trail.
                </p>
                <div class="form-group">
                    <label class="form-label form-label-required">Export Password</label>
                    <input type="password" class="form-control" name="exportPassword" placeholder="Enter export password" required />
                </div>
                <div style="background:#FEF9C3; border:1px solid #CA8A04; border-radius:4px; padding:10px 14px; font-size:12px; color:#92400E; margin-top:12px;">
                    <strong>Default export password:</strong> export@TrackNGo2026
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeModal('exportModal')">Cancel</button>
                <button type="submit" class="btn btn-primary">
                    <i data-lucide="download"></i> Authorize &amp; Export
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openExportModal(type) {
            document.getElementById('export-type-input').value = type;
            openModal('exportModal');
        }
    </script>
}
