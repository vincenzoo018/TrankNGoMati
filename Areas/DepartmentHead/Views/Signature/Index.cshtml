@{
    ViewData["Title"] = "Digital Signatures";
}

<div class="page-header animate-fade-in">
    <div class="page-header-left">
        <h1 class="page-title">Digital E-Signature</h1>
        <p class="page-subtitle">Provide your verifiable digital signature for final endorsements and approvals</p>
    </div>
</div>

<div class="grid animate-fade-in" style="grid-template-columns: 2fr 1fr; gap: 24px;">
    <!-- Signature Pad -->
    <div class="card">
        <div class="card-header"><span class="card-header-title">Sign Document: TNG-2026-0899</span></div>
        <div class="card-body">
            <div class="executive-summary">
                <h2>Travel Order for Manila Conference</h2>
                <p class="text-meta">Requesting Head: Juan Dela Cruz (HRMO)</p>
            </div>
            
            <p style="margin-bottom:16px;">Please draw your signature in the box below to authorize the endorsement.</p>
            <div class="signature-pad-container" id="signaturePad">
                <i data-lucide="pen-tool" style="width:48px;height:48px;color:var(--border);margin-bottom:16px;"></i>
                <span class="text-meta">Draw Signature Here</span>
            </div>
            
            <div style="display:flex; justify-content:space-between; margin-top:24px;">
                <button class="btn btn-ghost">Clear</button>
                <button class="btn btn-primary" onclick="signDocument()"><i data-lucide="lock"></i> Save Signature & Hash</button>
            </div>
        </div>
    </div>

    <!-- Verification Info -->
    <div class="card">
        <div class="card-header"><span class="card-header-title">Integrity Verification</span></div>
        <div class="card-body">
            <p class="text-meta" style="margin-bottom:16px;">All signatures are hashed using SHA-256 for non-repudiation and stored securely in the <strong>Digital_Signatures</strong> table.</p>
            
            <div class="form-group">
                <label class="form-label">Signatory User</label>
                <input type="text" class="form-control" value="Atty. Carlos Mendoza" readonly />
            </div>
            
            <div class="form-group" style="margin-top:16px;">
                <label class="form-label">Hash Preview</label>
                <div style="background:#1e293b; color:#e2e8f0; font-family:monospace; padding:12px; border-radius:4px; font-size:12px; word-break:break-all;">
                    Awaiting Signature Input...
                </div>
            </div>
        </div>
    </div>
</div>
