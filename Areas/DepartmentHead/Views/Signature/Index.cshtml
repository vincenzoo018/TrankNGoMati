@{
    ViewData["Title"] = "Digital Signatures";
}

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title">Digital Signatures</h1>
        <p class="page-subtitle">Sign, verify, and manage digital signatures for document approvals</p>
    </div>
</div>

<div style="display:grid; grid-template-columns:1fr 1fr; gap:24px;">
    <!-- Signature Pad -->
    <div class="card">
        <div class="card-header">
            <span class="card-header-title">Signature Pad</span>
        </div>
        <div class="card-body">
            <div class="form-group">
                <label class="form-label form-label-required">Document Reference</label>
                <select class="form-control">
                    <option>TNG-2026-0001 — Research Incentive Application</option>
                    <option>TNG-2026-0003 — Leave Application</option>
                    <option>TNG-2026-0005 — Purchase Request</option>
                    <option>TNG-2026-0007 — Special Order</option>
                </select>
            </div>
            <div class="signature-pad-wrapper">
                <p class="text-caption" style="margin-bottom:8px;">Draw your signature below</p>
                <canvas id="signatureCanvas" class="signature-pad-canvas" width="400" height="200"></canvas>
                <div class="signature-pad-actions">
                    <button class="btn btn-secondary btn-sm" onclick="signaturePad.clear()">
                        <i data-lucide="eraser"></i> Clear
                    </button>
                    <button class="btn btn-primary btn-sm" onclick="saveSignature()">
                        <i data-lucide="save"></i> Save Signature
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Verification -->
    <div class="card">
        <div class="card-header">
            <span class="card-header-title">Signature Verification</span>
        </div>
        <div class="card-body">
            <div class="form-group">
                <label class="form-label">Verify Document Signature</label>
                <div style="display:flex;gap:8px;">
                    <input type="text" class="form-control" placeholder="Enter reference number" />
                    <button class="btn btn-secondary" onclick="openModal('verifyModal')">
                        <i data-lucide="shield-check"></i> Verify
                    </button>
                </div>
            </div>

            <div style="margin-top:24px; padding:20px; border:1px solid var(--border); border-radius:var(--radius-card); text-align:center;">
                <i data-lucide="check-circle" style="width:48px;height:48px;color:var(--brand);margin-bottom:12px;"></i>
                <h2 class="h2">Signature Verified</h2>
                <p class="text-meta" style="margin-top:4px;">TNG-2026-0002 — Signed by Hon. Mayor</p>
                <p class="text-meta">Signed on: June 18, 2026 — 3:45 PM</p>
                <span class="badge badge-completed" style="margin-top:8px;">Verified</span>
            </div>
        </div>
    </div>
</div>

<!-- Signature History -->
<div class="card" style="margin-top:24px;">
    <div class="card-header">
        <span class="card-header-title">Signature History</span>
    </div>
    <div class="table-wrapper" style="border:none;border-radius:0;">
        <table>
            <thead>
                <tr>
                    <th>Ref No</th>
                    <th>Document</th>
                    <th>Signed By</th>
                    <th>Role</th>
                    <th>Signed At</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>TNG-2026-0002</td>
                    <td>Travel Order — Mayor's Office Staff</td>
                    <td>Hon. Mayor</td>
                    <td>Authorized Signatory</td>
                    <td>Jun 18, 2026 — 3:45 PM</td>
                    <td><span class="badge badge-completed">Verified</span></td>
                    <td>
                        <button class="btn btn-ghost btn-icon btn-sm" title="View" onclick="openModal('verifyModal')"><i data-lucide="eye"></i></button>
                        <button class="btn btn-ghost btn-icon btn-sm" title="Re-sign" onclick="showToast('Re-sign feature ready','success')"><i data-lucide="refresh-cw"></i></button>
                    </td>
                </tr>
                <tr>
                    <td>TNG-2026-0006</td>
                    <td>Certificate of Indigency — Maria Garcia</td>
                    <td>Dr. Ana Reyes</td>
                    <td>Department Head</td>
                    <td>Jun 26, 2026 — 11:20 AM</td>
                    <td><span class="badge badge-completed">Verified</span></td>
                    <td>
                        <button class="btn btn-ghost btn-icon btn-sm" title="View" onclick="openModal('verifyModal')"><i data-lucide="eye"></i></button>
                        <button class="btn btn-ghost btn-icon btn-sm" title="Re-sign" onclick="showToast('Re-sign feature ready','success')"><i data-lucide="refresh-cw"></i></button>
                    </td>
                </tr>
                <tr>
                    <td>TNG-2026-0001</td>
                    <td>Research Incentive — Dr. Santos</td>
                    <td>Atty. Carlos Mendoza</td>
                    <td>City Administrator</td>
                    <td>Jun 17, 2026 — 4:10 PM</td>
                    <td><span class="badge badge-completed">Verified</span></td>
                    <td>
                        <button class="btn btn-ghost btn-icon btn-sm" title="View" onclick="openModal('verifyModal')"><i data-lucide="eye"></i></button>
                        <button class="btn btn-ghost btn-icon btn-sm" title="Re-sign" onclick="showToast('Re-sign feature ready','success')"><i data-lucide="refresh-cw"></i></button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Verify Signature Modal -->
<div class="modal-overlay" id="verifyModal">
    <div class="modal">
        <div class="modal-header">
            <h3 class="modal-title">Signature Verification</h3>
            <button class="modal-close" onclick="closeModal('verifyModal')"><i data-lucide="x"></i></button>
        </div>
        <div class="modal-body" style="text-align:center;">
            <i data-lucide="shield-check" style="width:48px;height:48px;color:var(--brand);margin-bottom:16px;"></i>
            <h2 class="h2">Signature is Authentic</h2>
            <p class="text-meta" style="margin-top:8px;">This digital signature has been verified and matches the stored record.</p>
            <div style="margin-top:16px; padding:12px; border:1px solid var(--border); border-radius:var(--radius-card); text-align:left;">
                <div style="display:flex; justify-content:space-between; margin-bottom:6px;">
                    <span class="text-meta">Signer</span><span>Hon. Mayor</span>
                </div>
                <div style="display:flex; justify-content:space-between; margin-bottom:6px;">
                    <span class="text-meta">Document</span><span>TNG-2026-0002</span>
                </div>
                <div style="display:flex; justify-content:space-between;">
                    <span class="text-meta">Signed At</span><span>Jun 18, 2026 3:45 PM</span>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-primary" onclick="closeModal('verifyModal')">Close</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
function saveSignature() {
    if (signaturePad.isEmpty()) {
        showToast('Please draw your signature first.', 'error');
        return;
    }
    var data = signaturePad.toBase64();
    showToast('Signature saved and verified successfully!', 'success');
    signaturePad.clear();
}
</script>
}
