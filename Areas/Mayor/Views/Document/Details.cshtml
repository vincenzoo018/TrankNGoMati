@model TrackNGoMati.Models.Document
@{
    ViewData["Title"] = "Document Details";
}

<!-- Page Header -->
<div class="page-header animate-fade-in" style="align-items:center; margin-bottom: 24px; border-bottom: 1px solid var(--border); padding-bottom: 16px;">
    <div class="page-header-left">
        <h1 class="page-title" style="font-size: 24px;">@Model.TrackingNumber</h1>
        <p class="page-subtitle" style="font-size: 14px;">@Model.Title — @Model.SubmittedBy</p>
    </div>
    <div class="page-header-right" style="display: flex; gap: 8px;">
        <a href="/Mayor/Document" class="btn btn-secondary" style="padding: 8px 16px; border-color:var(--border);">
            <i data-lucide="arrow-left"></i> Back
        </a>
        <button class="btn btn-secondary" onclick="window.print()" style="padding: 8px 16px; border-color:var(--border);">
            <i data-lucide="printer"></i> Print
        </button>
        <button class="btn btn-secondary" style="padding: 8px 16px; border-color:var(--border);">
            <i data-lucide="download"></i> Export
        </button>
        <button class="btn btn-primary" style="padding: 8px 16px;" onclick="openModal('signatureModal')">
            <i data-lucide="pen-tool"></i> Sign &amp; Approve
        </button>
        <button class="btn" style="padding: 8px 16px; border: 1px solid #EF4444; color: #EF4444; background: white;">
            <i data-lucide="undo-2"></i> Return
        </button>
    </div>
</div>

<!-- Stepper -->
<div class="animate-fade-in" style="display: flex; justify-content: center; align-items: center; margin-bottom: 32px; padding: 0 40px;">
    @for (int i = 1; i <= Model.TotalSteps; i++)
    {
        var label = i switch { 1 => "Submitted", 2 => "Endorsed", 3 => "Accepted", 4 => "Reviewed", 5 => "Approved", 6 => "Completed", _ => $"Step {i}" };
        
        <div style="display: flex; flex-direction: column; align-items: center; position: relative; z-index: 1;">
            @if (i < Model.CurrentStepIndex) {
                <div style="width: 32px; height: 32px; border-radius: 50%; background-color: var(--brand); color: white; display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 14px;">@i</div>
                <div style="margin-top: 8px; font-size: 11px; font-weight: 600; color: var(--ink);">@label</div>
            } else if (i == Model.CurrentStepIndex) {
                <div style="width: 32px; height: 32px; border-radius: 50%; background-color: white; border: 2px solid var(--brand); color: var(--brand); display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 14px;">@i</div>
                <div style="margin-top: 8px; font-size: 11px; font-weight: 600; color: var(--brand);">@label</div>
            } else {
                <div style="width: 32px; height: 32px; border-radius: 50%; background-color: white; border: 1px solid var(--border); color: var(--ink-muted); display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 14px;">@i</div>
                <div style="margin-top: 8px; font-size: 11px; font-weight: 500; color: var(--ink-muted);">@label</div>
            }
        </div>
        
        @if (i < Model.TotalSteps)
        {
            <div style="flex: 1; height: 1px; background-color: @(i < Model.CurrentStepIndex ? "var(--brand)" : "var(--border)"); margin: 0 16px; margin-bottom: 20px;"></div>
        }
    }
</div>

<div class="animate-fade-in" style="display: flex; gap: 24px; align-items: flex-start;">
    <!-- LEFT COLUMN -->
    <div style="flex: 2; display: flex; flex-direction: column; gap: 24px;">
        
        <!-- Document Information -->
        <div class="card" style="margin: 0; border-radius: 8px;">
            <div class="card-header" style="border-bottom: 1px solid var(--border); padding: 16px 24px; display: flex; justify-content: space-between; align-items: center;">
                <h3 style="margin: 0; font-size: 16px; font-weight: 600; color: var(--ink);">Document Information</h3>
                @{
                    var statusText = Model.CurrentStatus switch {
                        1 => "PENDING",
                        2 => "IN PROGRESS",
                        3 => "COMPLETED",
                        4 => "RETURNED",
                        _ => "UNKNOWN"
                    };
                }
                <span style="border: 1px solid var(--brand); color: var(--brand); padding: 4px 12px; border-radius: 4px; font-size: 11px; font-weight: 600; letter-spacing: 0.5px;">@statusText</span>
            </div>
            <div class="card-body" style="padding: 24px;">
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
                    <!-- Col 1 -->
                    <div style="display: flex; flex-direction: column; gap: 24px;">
                        <div>
                            <div style="font-size: 10px; font-weight: 600; color: var(--ink-muted); margin-bottom: 4px; text-transform: uppercase;">Reference No</div>
                            <div style="font-size: 14px; color: var(--ink);">@Model.TrackingNumber</div>
                        </div>
                        <div>
                            <div style="font-size: 10px; font-weight: 600; color: var(--ink-muted); margin-bottom: 4px; text-transform: uppercase;">Department</div>
                            <div style="font-size: 14px; color: var(--ink);">@(Model.OriginatingDepartment ?? "HRMO")</div>
                        </div>
                        <div>
                            <div style="font-size: 10px; font-weight: 600; color: var(--ink-muted); margin-bottom: 4px; text-transform: uppercase;">Submitted By</div>
                            <div style="font-size: 14px; color: var(--ink);">@Model.SubmittedBy</div>
                        </div>
                        <div>
                            <div style="font-size: 10px; font-weight: 600; color: var(--ink-muted); margin-bottom: 4px; text-transform: uppercase;">Current Step</div>
                            <div style="font-size: 14px; color: var(--ink);">Step @Model.CurrentStepIndex of @Model.TotalSteps — Accepted</div>
                        </div>
                    </div>
                    <!-- Col 2 -->
                    <div style="display: flex; flex-direction: column; gap: 24px;">
                        <div>
                            <div style="font-size: 10px; font-weight: 600; color: var(--ink-muted); margin-bottom: 4px; text-transform: uppercase;">Document Type</div>
                            <div style="font-size: 14px; color: var(--ink);">@Model.DocumentType</div>
                        </div>
                        <div>
                            <div style="font-size: 10px; font-weight: 600; color: var(--ink-muted); margin-bottom: 4px; text-transform: uppercase;">Date Filed</div>
                            <div style="font-size: 14px; color: var(--ink);">@Model.DateFiled.ToString("MMMM dd, yyyy")</div>
                        </div>
                        <div>
                            <div style="font-size: 10px; font-weight: 600; color: var(--ink-muted); margin-bottom: 4px; text-transform: uppercase;">ARTA Tier</div>
                            <div style="font-size: 14px; color: var(--ink);">Simple — @Model.ArtaprocessingDays working days</div>
                        </div>
                        <div>
                            <div style="font-size: 10px; font-weight: 600; color: var(--ink-muted); margin-bottom: 8px; text-transform: uppercase;">ARTA Status</div>
                            <span style="border: 1px solid var(--brand); color: var(--brand); padding: 4px 8px; border-radius: 4px; font-size: 11px; font-weight: 700; width: fit-content; display: block;">ON TRACK</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Attachments -->
        <div class="card" style="margin: 0; border-radius: 8px;">
            <div class="card-header" style="border-bottom: none; padding: 16px 24px;">
                <h3 style="margin: 0; font-size: 16px; font-weight: 600; color: var(--ink);">Attachments</h3>
            </div>
            <div class="card-body" style="padding: 0 24px 24px 24px; display: flex; gap: 16px; flex-wrap: wrap;">
                @if (!string.IsNullOrEmpty(Model.AttachmentPath))
                {
                    <a href="@Model.AttachmentPath" target="_blank" style="display: flex; align-items: center; gap: 8px; padding: 8px 12px; border: 1px solid var(--border); border-radius: 6px; text-decoration: none; color: var(--brand); font-size: 13px;">
                        <i data-lucide="file" style="width: 16px; height: 16px;"></i> @System.IO.Path.GetFileName(Model.AttachmentPath) (Scanned)
                    </a>
                }
                <!-- Dummy attachments to match design -->
                <a href="#" style="display: flex; align-items: center; gap: 8px; padding: 8px 12px; border: 1px solid var(--border); border-radius: 6px; text-decoration: none; color: var(--brand); font-size: 13px;">
                    <i data-lucide="file" style="width: 16px; height: 16px;"></i> research_application.pdf <span style="color:var(--ink-muted);">(245 KB)</span>
                </a>
                <a href="#" style="display: flex; align-items: center; gap: 8px; padding: 8px 12px; border: 1px solid var(--border); border-radius: 6px; text-decoration: none; color: var(--brand); font-size: 13px;">
                    <i data-lucide="file" style="width: 16px; height: 16px;"></i> supporting_docs.pdf <span style="color:var(--ink-muted);">(128 KB)</span>
                </a>
            </div>
        </div>

        <!-- Routing Slip Preview -->
        <div class="card" style="margin: 0; border-radius: 8px;">
            <div class="card-header" style="border-bottom: 1px solid var(--border); padding: 16px 24px; display: flex; justify-content: space-between; align-items: center;">
                <h3 style="margin: 0; font-size: 16px; font-weight: 600; color: var(--ink);">Routing Slip</h3>
                <a href="/Mayor/Document/RoutingSlip/@Model.TrackingNumber" style="display: flex; align-items: center; gap: 6px; color: var(--ink-muted); text-decoration: none; font-size: 13px;">
                    <i data-lucide="printer" style="width: 16px; height: 16px;"></i> Print Slip
                </a>
            </div>
            <div class="card-body" style="padding: 24px; min-height: 200px; background: #fafafa;">
                <!-- Placeholder for visual match -->
                <div style="border: 1px solid #BFDBFE; border-radius: 8px; background: white; overflow: hidden;">
                    <div style="background-color: #EFF6FF; text-align: center; padding: 12px; font-weight: 700; font-size: 12px; color: #1E3A8A; letter-spacing: 0.5px; border-bottom: 1px solid #BFDBFE;">
                        ROUTING SLIP (MAIL)
                    </div>
                    <div style="padding: 20px; font-size: 13px; color: var(--ink);">
                        <p><strong>TO:</strong> Office of the Mayor</p>
                        <p><strong>DOCUMENT ATTACHED IS:</strong> Research Application + 2 attachments</p>
                    </div>
                </div>
            </div>
        </div>

    </div>
    
    <!-- RIGHT COLUMN -->
    <div style="flex: 1;">
        <div class="card" style="margin: 0; border-radius: 8px;">
            <div class="card-header" style="border-bottom: 1px solid var(--border); padding: 16px 24px; display: flex; align-items: center; gap: 8px;">
                <i data-lucide="activity" style="width: 18px; height: 18px; color: var(--ink);"></i>
                <h3 style="margin: 0; font-size: 16px; font-weight: 600; color: var(--ink);">Document Tracer</h3>
            </div>
            <div class="card-body" style="padding: 24px;">
                <div style="position: relative; padding-left: 20px;">
                    <!-- Line -->
                    <div style="position: absolute; left: 15px; top: 16px; bottom: 0; width: 2px; background: var(--border);"></div>

                    <!-- Item 1 -->
                    <div style="position: relative; padding-bottom: 24px; padding-left: 24px;">
                        <div style="position: absolute; left: -16px; top: 0; width: 24px; height: 24px; border-radius: 50%; background: var(--brand); color: white; display: flex; justify-content: center; align-items: center; font-size: 10px; font-weight: 700; border: 4px solid white; box-sizing: content-box;">RC</div>
                        <div style="font-weight: 600; font-size: 13px; color: var(--ink);">Document Submitted</div>
                        <div style="font-size: 12px; color: var(--ink-muted); margin-top: 4px;">Document registered and tracking number assigned.</div>
                        <div style="font-size: 11px; color: var(--ink-muted); margin-top: 4px;">@Model.DateFiled.ToString("MMM dd, yyyy \u2014 h:mm tt")</div>
                    </div>

                    <!-- Item 2 -->
                    <div style="position: relative; padding-bottom: 24px; padding-left: 24px;">
                        <div style="position: absolute; left: -16px; top: 0; width: 24px; height: 24px; border-radius: 50%; background: var(--brand); color: white; display: flex; justify-content: center; align-items: center; font-size: 10px; font-weight: 700; border: 4px solid white; box-sizing: content-box;">RC</div>
                        <div style="font-weight: 600; font-size: 13px; color: var(--ink);">QR Code Generated</div>
                        <div style="font-size: 12px; color: var(--ink-muted); margin-top: 4px;">QR code created for document tracking.</div>
                        <div style="font-size: 11px; color: var(--ink-muted); margin-top: 4px;">@Model.DateFiled.ToString("MMM dd, yyyy \u2014 h:mm tt")</div>
                    </div>

                    <!-- Item 3 -->
                    <div style="position: relative; padding-bottom: 24px; padding-left: 24px;">
                        <div style="position: absolute; left: -16px; top: 0; width: 24px; height: 24px; border-radius: 50%; background: var(--brand); color: white; display: flex; justify-content: center; align-items: center; font-size: 10px; font-weight: 700; border: 4px solid white; box-sizing: content-box;">SM</div>
                        <div style="font-weight: 600; font-size: 13px; color: var(--ink);">SMS Notification Sent</div>
                        <div style="font-size: 12px; color: var(--ink-muted); margin-top: 4px;">Status update sent to @Model.SubmittedBy (@Model.ContactNumber).</div>
                        <div style="font-size: 11px; color: var(--ink-muted); margin-top: 4px;">@Model.DateFiled.ToString("MMM dd, yyyy \u2014 h:mm tt")</div>
                    </div>

                    <!-- Item 4 -->
                    <div style="position: relative; padding-bottom: 0; padding-left: 24px;">
                        <div style="position: absolute; left: -16px; top: 0; width: 24px; height: 24px; border-radius: 50%; background: var(--brand); color: white; display: flex; justify-content: center; align-items: center; font-size: 10px; font-weight: 700; border: 4px solid white; box-sizing: content-box;">DH</div>
                        <div style="font-weight: 600; font-size: 13px; color: var(--ink);">Endorsed by Dept. Head</div>
                        <div style="font-size: 12px; color: var(--ink-muted); margin-top: 4px;">Document endorsed for processing by Dept Head — @(Model.OriginatingDepartment ?? "HRMO").</div>
                        <div style="font-size: 11px; color: var(--ink-muted); margin-top: 4px;">@Model.DateFiled.AddDays(1).ToString("MMM dd, yyyy \u2014 h:mm tt")</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Signature Modal -->
<div class="modal-overlay" id="signatureModal">
    <div class="modal animate-fade-in" style="max-width: 500px;">
        <div class="modal-header">
            <h3 class="modal-title">Sign &amp; Approve Document</h3>
            <button class="modal-close" onclick="closeModal('signatureModal')"><i data-lucide="x"></i></button>
        </div>
        <div class="modal-body">
            <p style="margin-bottom:12px;">Please provide your digital signature before forwarding this document.</p>
            <div style="border:2px dashed var(--border); border-radius:4px; background:#FAFAFA; margin-bottom:12px;">
                <canvas id="sigCanvas" width="460" height="150" style="cursor:crosshair; touch-action:none; width:100%;"></canvas>
            </div>
            <div style="display:flex; justify-content:space-between; align-items:center;">
                <button type="button" class="btn btn-ghost" onclick="clearSig()">
                    <i data-lucide="trash-2"></i> Clear
                </button>
                <div style="font-size:11px; color:var(--ink-muted);" id="hash-preview">Awaiting signature...</div>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" onclick="closeModal('signatureModal')">Cancel</button>
            <button type="button" class="btn btn-primary" onclick="submitSignature()">
                <i data-lucide="check"></i> Confirm &amp; Forward
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var canvas = document.getElementById('sigCanvas');
        var ctx = canvas.getContext('2d');
        ctx.strokeStyle = '#0F172A';
        ctx.lineWidth = 2;
        ctx.lineCap = 'round';
        var drawing = false;

        function getPos(e) {
            var r = canvas.getBoundingClientRect();
            var scaleX = canvas.width / r.width;
            var scaleY = canvas.height / r.height;
            var clientX = e.touches ? e.touches[0].clientX : e.clientX;
            var clientY = e.touches ? e.touches[0].clientY : e.clientY;
            return { x: (clientX - r.left) * scaleX, y: (clientY - r.top) * scaleY };
        }

        canvas.addEventListener('mousedown', function(e) { drawing = true; var p = getPos(e); ctx.beginPath(); ctx.moveTo(p.x, p.y); });
        canvas.addEventListener('mousemove', function(e) { if (!drawing) return; var p = getPos(e); ctx.lineTo(p.x, p.y); ctx.stroke(); });
        canvas.addEventListener('mouseup', function() { drawing = false; updateHash(); });
        canvas.addEventListener('mouseleave', function() { drawing = false; });
        canvas.addEventListener('touchstart', function(e) { e.preventDefault(); drawing = true; var p = getPos(e); ctx.beginPath(); ctx.moveTo(p.x, p.y); }, {passive:false});
        canvas.addEventListener('touchmove', function(e) { e.preventDefault(); if (!drawing) return; var p = getPos(e); ctx.lineTo(p.x, p.y); ctx.stroke(); }, {passive:false});
        canvas.addEventListener('touchend', function() { drawing = false; updateHash(); });

        function clearSig() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            document.getElementById('hash-preview').textContent = 'Awaiting signature...';
        }

        function updateHash() {
            var blank = document.createElement('canvas');
            blank.width = canvas.width;
            blank.height = canvas.height;
            if (canvas.toDataURL() !== blank.toDataURL()) {
                var mockHash = 'sha256:' + [...Array(64)].map(() => Math.floor(Math.random()*16).toString(16)).join('');
                document.getElementById('hash-preview').textContent = mockHash.substring(0, 20) + '...';
            }
        }

        function submitSignature() {
            var blank = document.createElement('canvas');
            blank.width = canvas.width;
            blank.height = canvas.height;
            if (canvas.toDataURL() === blank.toDataURL()) {
                showToast('Please draw your signature before endorsing.', 'error');
                return;
            }
            
            showToast('Document signed and forwarded successfully!', 'success');
            closeModal('signatureModal');
            
            // Redirect after a short delay
            setTimeout(function() {
                window.location.href = '/Mayor/Document';
            }, 1500);
        }
    </script>
}
