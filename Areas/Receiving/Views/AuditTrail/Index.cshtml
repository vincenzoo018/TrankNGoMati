@model IEnumerable<TrackNGoMati.Models.AuditTrailEntry>
@{
    ViewData["Title"] = "Audit Trail";
}

<div class="page-header animate-fade-in" style="margin-bottom: 24px;">
    <div class="page-header-left">
        <h1 class="page-title">Audit Trail</h1>
        <p class="page-subtitle">Comprehensive tracking of all system activities</p>
    </div>
</div>

<div class="card animate-fade-in" style="border-radius: 8px;">
    <div style="padding: 16px; border-bottom: 1px solid var(--border);">
        <div class="search-input" style="width: 100%;">
            <i data-lucide="search"></i>
            <input type="text" placeholder="Search audit trail..." style="padding-left: 36px; height: 40px;" />
        </div>
    </div>
    
    <div class="table-wrapper" style="border:none;">
        <table>
            <thead>
                <tr>
                    <th style="padding-left: 20px;">TIMESTAMP</th>
                    <th>USER</th>
                    <th>DOCUMENT REF</th>
                    <th>ACTION</th>
                    <th>DETAILS</th>
                    <th>IP ADDRESS</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var entry in Model)
                {
                    <tr>
                        <td style="padding-left: 20px;">@entry.Timestamp.ToString("MMM dd, yyyy HH:mm:ss")</td>
                        <td style="font-weight:500; color:var(--ink);">@(entry.User?.FullName ?? "System")</td>
                        <td>
                            @if(entry.Document != null) {
                                <a href="#" style="color:var(--brand);">@entry.Document.TrackingNumber</a>
                            } else {
                                <span style="color:var(--ink-muted);">-</span>
                            }
                        </td>
                        <td>
                            <span style="display:inline-block; padding:2px 8px; border-radius:4px; background:#F1F5F9; font-size:12px; font-weight:600; color:var(--ink);">@entry.Action</span>
                        </td>
                        <td>@entry.Details</td>
                        <td style="font-family:monospace; font-size:12px; color:var(--ink-muted);">@entry.Ipaddress</td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" style="text-align:center; padding:40px; color:var(--ink-muted);">No audit entries found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
