@{
    ViewData["Title"] = "Dashboard";
}

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title">Dashboard</h1>
        <p class="page-subtitle">Welcome back! Here's your document management overview.</p>
    </div>
    <div class="page-header-right">
        <a href="/Documents/Create" class="btn btn-primary">
            <i data-lucide="plus"></i> New Document
        </a>
    </div>
</div>

<!-- Stat Cards -->
<div class="stat-grid">
    <div class="stat-card">
        <div class="stat-card-icon brand">
            <i data-lucide="file-text"></i>
        </div>
        <div class="stat-card-info">
            <span class="stat-card-value">247</span>
            <span class="stat-card-label">Total Documents</span>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-card-icon brand">
            <i data-lucide="clock"></i>
        </div>
        <div class="stat-card-info">
            <span class="stat-card-value">38</span>
            <span class="stat-card-label">Pending Review</span>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-card-icon brand">
            <i data-lucide="check-circle"></i>
        </div>
        <div class="stat-card-info">
            <span class="stat-card-value">182</span>
            <span class="stat-card-label">Completed</span>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-card-icon destructive">
            <i data-lucide="alert-triangle"></i>
        </div>
        <div class="stat-card-info">
            <span class="stat-card-value">12</span>
            <span class="stat-card-label">ARTA Escalated</span>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="chart-grid">
    <div class="card">
        <div class="card-header">
            <span class="card-header-title">Documents by Status</span>
            <span class="text-meta">Current period</span>
        </div>
        <div class="card-body chart-container">
            <canvas id="statusChart" height="220"></canvas>
        </div>
    </div>
    <div class="card">
        <div class="card-header">
            <span class="card-header-title">Processing Turnaround</span>
            <span class="text-meta">Average days</span>
        </div>
        <div class="card-body chart-container">
            <canvas id="turnaroundChart" height="220"></canvas>
        </div>
    </div>
</div>

<!-- Recent Documents Table -->
<div class="card" style="margin-top:16px;">
    <div class="card-header">
        <span class="card-header-title">Recent Documents</span>
        <a href="/Documents" class="btn btn-secondary btn-sm">View All</a>
    </div>
    <div class="table-wrapper" style="border:none; border-radius:0;">
        <table>
            <thead>
                <tr>
                    <th>Ref No</th>
                    <th>Title</th>
                    <th>Type</th>
                    <th>Department</th>
                    <th>Date Filed</th>
                    <th>Status</th>
                    <th>ARTA</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><a href="/Documents/Details/TNG-2026-0001">TNG-2026-0001</a></td>
                    <td>Research Incentive Application — Dr. Santos</td>
                    <td>Research Incentive</td>
                    <td>HRMO</td>
                    <td>Jun 15, 2026</td>
                    <td><span class="badge badge-in-progress">In Progress</span></td>
                    <td><span class="badge badge-on-track">On Track</span></td>
                    <td><a href="/Documents/Details/TNG-2026-0001" class="btn btn-ghost btn-sm"><i data-lucide="eye"></i></a></td>
                </tr>
                <tr>
                    <td><a href="/Documents/Details/TNG-2026-0002">TNG-2026-0002</a></td>
                    <td>Travel Order — Mayor's Office Staff</td>
                    <td>Travel Order</td>
                    <td>Mayor's Office</td>
                    <td>Jun 18, 2026</td>
                    <td><span class="badge badge-completed">Completed</span></td>
                    <td><span class="badge badge-completed">Completed</span></td>
                    <td><a href="/Documents/Details/TNG-2026-0002" class="btn btn-ghost btn-sm"><i data-lucide="eye"></i></a></td>
                </tr>
                <tr>
                    <td><a href="/Documents/Details/TNG-2026-0003">TNG-2026-0003</a></td>
                    <td>Leave Application — Juan Dela Cruz</td>
                    <td>Leave Application</td>
                    <td>CDRRMO</td>
                    <td>Jun 20, 2026</td>
                    <td><span class="badge badge-pending">Pending</span></td>
                    <td><span class="badge badge-warning">Due Soon</span></td>
                    <td><a href="/Documents/Details/TNG-2026-0003" class="btn btn-ghost btn-sm"><i data-lucide="eye"></i></a></td>
                </tr>
                <tr>
                    <td><a href="/Documents/Details/TNG-2026-0004">TNG-2026-0004</a></td>
                    <td>Memorandum — Budget Allocation Q3</td>
                    <td>Memorandum</td>
                    <td>Budget Office</td>
                    <td>Jun 22, 2026</td>
                    <td><span class="badge badge-returned">Returned</span></td>
                    <td><span class="badge badge-overdue">Overdue</span></td>
                    <td><a href="/Documents/Details/TNG-2026-0004" class="btn btn-ghost btn-sm"><i data-lucide="eye"></i></a></td>
                </tr>
                <tr>
                    <td><a href="/Documents/Details/TNG-2026-0005">TNG-2026-0005</a></td>
                    <td>Purchase Request — Office Supplies</td>
                    <td>Purchase Request</td>
                    <td>GSO</td>
                    <td>Jun 25, 2026</td>
                    <td><span class="badge badge-in-progress">In Progress</span></td>
                    <td><span class="badge badge-on-track">On Track</span></td>
                    <td><a href="/Documents/Details/TNG-2026-0005" class="btn btn-ghost btn-sm"><i data-lucide="eye"></i></a></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Status Doughnut Chart
    var ctx1 = document.getElementById('statusChart');
    if (ctx1) {
        new Chart(ctx1, {
            type: 'doughnut',
            data: {
                labels: ['Completed', 'In Progress', 'Pending', 'Returned'],
                datasets: [{
                    data: [182, 38, 15, 12],
                    backgroundColor: ['#1A56DB', '#EBF2FF', '#93B4F5', '#DC2626'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            font: { family: "'Plus Jakarta Sans', sans-serif", size: 11 },
                            padding: 16
                        }
                    }
                }
            }
        });
    }

    // Turnaround Bar Chart
    var ctx2 = document.getElementById('turnaroundChart');
    if (ctx2) {
        new Chart(ctx2, {
            type: 'bar',
            data: {
                labels: ['HRMO', "Mayor's Office", 'CDRRMO', 'Budget', 'GSO', 'Engineering'],
                datasets: [{
                    label: 'Avg. Days',
                    data: [2.1, 1.5, 4.2, 3.8, 2.7, 5.1],
                    backgroundColor: '#1A56DB',
                    borderRadius: 4,
                    barThickness: 24
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { color: '#E2E8F0' },
                        ticks: { font: { family: "'Plus Jakarta Sans', sans-serif", size: 11 } }
                    },
                    x: {
                        grid: { display: false },
                        ticks: { font: { family: "'Plus Jakarta Sans', sans-serif", size: 11 } }
                    }
                }
            }
        });
    }
});
</script>
}
