@{
    ViewData["Title"] = "Documents";
}

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title">Documents</h1>
        <p class="page-subtitle">Manage and track all documents in the system</p>
    </div>
    <div class="page-header-right">
        <button class="btn btn-secondary" onclick="openModal('exportModal')">
            <i data-lucide="download"></i> Export
        </button>
        <a href="/Documents/Create" class="btn btn-primary">
            <i data-lucide="plus"></i> New Document
        </a>
    </div>
</div>

<!-- Filter Bar -->
<div class="filter-bar">
    <div class="search-input">
        <i data-lucide="search"></i>
        <input type="text" id="tableSearch" placeholder="Search documents by reference, title, or department..." />
    </div>
    <select class="filter-select" id="statusFilter" onchange="filterBySelect('statusFilter','.table-wrapper table', 5)">
        <option value="">All Statuses</option>
        <option value="completed">Completed</option>
        <option value="in progress">In Progress</option>
        <option value="pending">Pending</option>
        <option value="returned">Returned</option>
    </select>
    <select class="filter-select" id="typeFilter">
        <option value="">All Types</option>
        <option>Research Incentive</option>
        <option>Travel Order</option>
        <option>Leave Application</option>
        <option>Memorandum</option>
        <option>Purchase Request</option>
        <option>Certificate</option>
        <option>Special Order</option>
        <option>Administrative Order</option>
        <option>Memo Circular</option>
    </select>
    <select class="filter-select" id="artaFilter">
        <option value="">All ARTA</option>
        <option value="on track">On Track</option>
        <option value="due soon">Due Soon</option>
        <option value="overdue">Overdue</option>
        <option value="completed">Completed</option>
    </select>
</div>

