@model IEnumerable<TrackNGoMati.Models.RoutingSlip>
@{
    ViewData["Title"] = "Routing Slips";
}

<div class="page-header animate-fade-in" style="margin-bottom: 24px;">
    <div class="page-header-left">
        <h1 class="page-title">Routing Slips</h1>
        <p class="page-subtitle">Track the physical transfer of documents between departments</p>
    </div>
</div>

<div class="card animate-fade-in" style="border-radius: 8px;">
    <div style="padding: 16px; border-bottom: 1px solid var(--border);">
        <div class="search-input" style="width: 100%;">
            <i data-lucide="search"></i>
            <input type="text" placeholder="Search routing slips..." style="padding-left: 36px; height: 40px;" />
        </div>
    </div>
    
    <div class="table-wrapper" style="border:none;">
        <table>
            <thead>
                <tr>
                    <th style="padding-left: 20px;">SLIP NO.</th>
                    <th>DOCUMENT REF</th>
                    <th>RECEIVED BY</th>
                    <th>SENDER</th>
                    <th>TARGET DEPT</th>
                    <th>STATUS</th>
                    <th>DATE RECEIVED</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var slip in Model)
                {
                    <tr>
                        <td style="padding-left: 20px; font-weight:600; color:var(--ink);">@slip.TrackingNumber</td>
                        <td><a href="/Receiving/Document/Details/@slip.Document?.TrackingNumber" style="color:var(--brand); text-decoration:underline;">@slip.Document?.TrackingNumber</a></td>
                        <td>@slip.ReceivedByUser?.FullName</td>
                        <td>@slip.SenderName</td>
                        <td>@slip.TargetDepartment?.DepartmentName</td>
                        <td>
                            @if(slip.SlipStatus == "Completed") {
                                <span class="badge badge-completed">@slip.SlipStatus</span>
                            } else {
                                <span class="badge badge-pending">@slip.SlipStatus</span>
                            }
                        </td>
                        <td>@slip.DateReceived.ToString("MMM dd, yyyy HH:mm")</td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="7" style="text-align:center; padding:40px; color:var(--ink-muted);">No routing slips found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
