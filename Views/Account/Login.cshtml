@{
    Layout = "~/Views/Shared/_LayoutLogin.cshtml";
    ViewData["Title"] = "Sign In";
}

<div class="login-wrapper">
    <!-- LEFT: Brand Panel -->
    <div class="login-brand">
        <div class="login-brand-logo">
            <svg width="60" height="60" viewBox="0 0 60 60" fill="none">
                <rect width="60" height="60" rx="12" fill="white" fill-opacity="0.2"/>
                <text x="50%" y="55%" dominant-baseline="middle" text-anchor="middle"
                      font-family="Plus Jakarta Sans, sans-serif" font-size="32" font-weight="700" fill="white">T</text>
            </svg>
        </div>
        <h1 class="login-brand-title">TrackNGo Mati</h1>
        <p class="login-brand-tagline">
            EODB-Compliant Smart Document Tracking &amp; Escalation System for the City Government of Mati
        </p>
        <div style="margin-top:40px; opacity:0.7; font-size:11px; text-align:center;">
            <p>Office of the Mayor</p>
            <p>City of Mati, Davao Oriental</p>
        </div>
    </div>

    <!-- RIGHT: Login Form -->
    <div class="login-form-side">
        <div class="login-card">
            <h2 class="login-card-title">Welcome Back</h2>
            <p class="login-card-sub">Sign in to your TrackNGo account</p>

            <form action="/Account/Login" method="post">
                <div class="form-group">
                    <label class="form-label form-label-required">Email Address</label>
                    <input type="email" class="form-control" name="email" placeholder="you@mati.gov.ph" required id="login-email" />
                </div>

                <div class="form-group">
                    <label class="form-label form-label-required">Password</label>
                    <input type="password" class="form-control" name="password" placeholder="Enter your password" required id="login-password" />
                </div>

                <div class="form-group">
                    <label class="form-label form-label-required">Sign In As</label>
                    <select class="form-control" name="role" id="login-role">
                        <option value="System Administrator">System Administrator</option>
                        <option value="Department Personnel">Department Personnel</option>
                        <option value="Department Head">Department Head</option>
                        <option value="Authorized Signatory">Authorized Signatory</option>
                        <option value="Client">Client / Document Requester</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-check">
                        <input type="checkbox" name="remember" id="login-remember" />
                        <span>Remember me</span>
                    </label>
                </div>

                <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center; padding:10px;" id="login-submit">
                    <i data-lucide="log-in"></i> Sign In
                </button>
            </form>

            <div style="margin-top:24px; text-align:center;">
                <p class="text-meta">TrackNGo Mati v1.0 &middot; RA 11032 Compliant</p>
            </div>
        </div>
    </div>
</div>
