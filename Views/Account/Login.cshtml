@{
    Layout = "~/Views/Shared/_LayoutLogin.cshtml";
    ViewData["Title"] = "Sign In";
}

<div class="login-wrapper">
    <!-- LEFT: Brand Panel -->
    <div class="login-brand">
        <div class="login-brand-logo">
            <svg width="60" height="60" viewBox="0 0 60 60" fill="none">
                <rect width="60" height="60" rx="12" fill="white" fill-opacity="0.2"/>
                <text x="50%" y="55%" dominant-baseline="middle" text-anchor="middle"
                      font-family="Plus Jakarta Sans, sans-serif" font-size="32" font-weight="700" fill="white">T</text>
            </svg>
        </div>
        <h1 class="login-brand-title">TrackNGo Mati</h1>
        <p class="login-brand-tagline">
            EODB-Compliant Smart Document Tracking &amp; Escalation System for the City Government of Mati
        </p>
        <div style="margin-top:40px; opacity:0.7; font-size:11px; text-align:center;">
            <p>Office of the Mayor</p>
            <p>City of Mati, Davao Oriental</p>
        </div>
    </div>

    <!-- RIGHT: Login Form -->
    <div class="login-form-side">
        <div class="login-card animate-fade-in">
            <h2 class="login-card-title">Welcome Back</h2>
            <p class="login-card-sub">Sign in to your TrackNGo account</p>

            @if (TempData["LoginError"] != null)
            {
                <div style="background:#FEF2F2; border:1px solid var(--destructive); border-radius:4px; padding:12px 16px; margin-bottom:16px; display:flex; align-items:center; gap:8px;">
                    <i data-lucide="alert-circle" style="width:16px;height:16px;color:var(--destructive);flex-shrink:0;"></i>
                    <span style="font-size:var(--fs-body); color:var(--destructive);">@TempData["LoginError"]</span>
                </div>
            }

            <form action="/Account/Login" method="post">
                <div class="form-group">
                    <label class="form-label form-label-required">Email / Username</label>
                    <div style="position:relative;">
                        <i data-lucide="mail" style="position:absolute;left:10px;top:50%;transform:translateY(-50%);width:15px;height:15px;color:var(--ink-muted);"></i>
                        <input type="text" class="form-control" name="username" id="login-username"
                               placeholder="you@mati.gov.ph" required autocomplete="username"
                               style="padding-left:34px;" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label form-label-required">Password</label>
                    <div style="position:relative;">
                        <i data-lucide="lock" style="position:absolute;left:10px;top:50%;transform:translateY(-50%);width:15px;height:15px;color:var(--ink-muted);"></i>
                        <input type="password" class="form-control" name="password" id="login-password"
                               placeholder="Enter your password" required autocomplete="current-password"
                               style="padding-left:34px; padding-right:40px;" />
                        <button type="button" onclick="togglePwd()" tabindex="-1"
                                style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;padding:0;">
                            <i data-lucide="eye" id="pwd-icon" style="width:15px;height:15px;color:var(--ink-muted);"></i>
                        </button>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-check">
                        <input type="checkbox" name="remember" id="login-remember" />
                        <span>Remember me</span>
                    </label>
                </div>

                <button type="submit" class="btn btn-primary" id="login-submit"
                        style="width:100%; justify-content:center; padding:10px;">
                    <i data-lucide="log-in"></i> Sign In
                </button>
            </form>

            <!-- Quick-Fill Demo Buttons -->
            <div style="margin-top:20px; border-top:1px solid var(--border); padding-top:16px;">
                <p style="font-size:10px; text-transform:uppercase; letter-spacing:0.5px; color:var(--ink-muted); font-weight:600; margin-bottom:8px;">
                    Quick Demo Login
                </p>
                <div style="display:flex; gap:6px; flex-wrap:wrap;">
                    <button onclick="fill('mayor@mati.gov.ph')"    class="btn btn-sm btn-secondary">Mayor</button>
                    <button onclick="fill('admin@mati.gov.ph')"    class="btn btn-sm btn-secondary">Admin</button>
                    <button onclick="fill('records@mati.gov.ph')"  class="btn btn-sm btn-secondary">Receiving</button>
                    <button onclick="fill('hrmo.head@mati.gov.ph')" class="btn btn-sm btn-secondary">Dept Head</button>
                    <button onclick="fill('cart@mati.gov.ph')"     class="btn btn-sm btn-secondary">CART</button>
                </div>
            </div>

            <div style="margin-top:16px; text-align:center;">
                <p class="text-meta">TrackNGo Mati v1.0 &middot; RA 11032 Compliant</p>
                <p class="text-meta" style="margin-top: 4px;">Demo Password: <strong>password123</strong></p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function fill(email) {
            document.getElementById('login-username').value = email;
            document.getElementById('login-password').value = 'password123';
        }
        function togglePwd() {
            var inp  = document.getElementById('login-password');
            var icon = document.getElementById('pwd-icon');
            if (inp.type === 'password') {
                inp.type = 'text';
                icon.setAttribute('data-lucide', 'eye-off');
            } else {
                inp.type = 'password';
                icon.setAttribute('data-lucide', 'eye');
            }
            lucide.createIcons();
        }
    </script>
}
