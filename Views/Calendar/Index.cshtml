@{
    ViewData["Title"] = "Global Calendar & Deadlines";
    Layout = ViewBag.Layout;
}

<div class="page-header animate-fade-in" style="margin-bottom: 24px;">
    <h1 class="page-title">SLA Deadlines Calendar</h1>
    <p class="page-subtitle">Track ARTA processing deadlines across all active documents.</p>
</div>

<div class="card animate-fade-in" style="padding: 24px; border-radius: 8px;">
    <!-- FullCalendar CSS and JS -->
    <script src='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.js'></script>
    <div id='calendar'></div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        var calendarEl = document.getElementById('calendar');
        var calendar = new FullCalendar.Calendar(calendarEl, {
            initialView: 'dayGridMonth',
            headerToolbar: {
                left: 'prev,next today',
                center: 'title',
                right: 'dayGridMonth,timeGridWeek,listWeek'
            },
            events: '/Calendar/GetEvents',
            eventClick: function(info) {
                if (info.event.url) {
                    window.location.href = info.event.url;
                    info.jsEvent.preventDefault(); 
                }
            }
        });
        calendar.render();
    });
</script>
