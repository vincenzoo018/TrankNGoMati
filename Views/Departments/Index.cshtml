@{
    ViewData["Title"] = "Department Management";
}

<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title">Department Management</h1>
        <p class="page-subtitle">Manage City of Mati departments and office assignments</p>
    </div>
    <div class="page-header-right">
        <button class="btn btn-primary" onclick="openModal('createDeptModal')">
            <i data-lucide="building-2"></i> Add Department
        </button>
    </div>
</div>

<div class="filter-bar">
    <div class="search-input">
        <i data-lucide="search"></i>
        <input type="text" id="tableSearch" placeholder="Search departments..." />
    </div>
</div>

<div class="card">
    <div class="table-wrapper" style="border:none;">
        <table>
            <thead>
                <tr><th>ID</th><th>Department Name</th><th>Head</th><th>Personnel Count</th><th>Actions</th></tr>
            </thead>
            <tbody>
                <tr><td>1</td><td>Office of the Mayor</td><td>Hon. Mayor</td><td>12</td>
                    <td class="table-actions"><button class="btn btn-ghost btn-icon btn-sm" onclick="openModal('editDeptModal')"><i data-lucide="pencil"></i></button><button class="btn btn-ghost btn-icon btn-sm" onclick="openModal('deleteDeptModal')"><i data-lucide="trash-2"></i></button></td></tr>
                <tr><td>2</td><td>City Administrator's Office</td><td>Atty. Carlos Mendoza</td><td>8</td>
                    <td class="table-actions"><button class="btn btn-ghost btn-icon btn-sm" onclick="openModal('editDeptModal')"><i data-lucide="pencil"></i></button><button class="btn btn-ghost btn-icon btn-sm" onclick="openModal('deleteDeptModal')"><i data-lucide="trash-2"></i></button></td></tr>
                <tr><td>3</td><td>HRMO</td><td>Dr. Ana Reyes</td><td>15</td>
                    <td class="table-actions"><button class="btn btn-ghost btn-icon btn-sm" onclick="openModal('editDeptModal')"><i data-lucide="pencil"></i></button><button class="btn btn-ghost btn-icon btn-sm" onclick="openModal('deleteDeptModal')"><i data-lucide="trash-2"></i></button></td></tr>
                <tr><td>4</td><td>Budget Office</td><td>Maria Lopez</td><td>6</td>
                    <td class="table-actions"><button class="btn btn-ghost btn-icon btn-sm" onclick="openModal('editDeptModal')"><i data-lucide="pencil"></i></button><button class="btn btn-ghost btn-icon btn-sm" onclick="openModal('deleteDeptModal')"><i data-lucide="trash-2"></i></button></td></tr>
                <tr><td>5</td><td>CDRRMO</td><td>Engr. Pedro Cruz</td><td>20</td>
                    <td class="table-actions"><button class="btn btn-ghost btn-icon btn-sm" onclick="openModal('editDeptModal')"><i data-lucide="pencil"></i></button><button class="btn btn-ghost btn-icon btn-sm" onclick="openModal('deleteDeptModal')"><i data-lucide="trash-2"></i></button></td></tr>
                <tr><td>6</td><td>GSO</td><td>Jose Santos</td><td>10</td>
                    <td class="table-actions"><button class="btn btn-ghost btn-icon btn-sm" onclick="openModal('editDeptModal')"><i data-lucide="pencil"></i></button><button class="btn btn-ghost btn-icon btn-sm" onclick="openModal('deleteDeptModal')"><i data-lucide="trash-2"></i></button></td></tr>
                <tr><td>7</td><td>Engineering Office</td><td>Engr. Ramon Villar</td><td>18</td>
                    <td class="table-actions"><button class="btn btn-ghost btn-icon btn-sm" onclick="openModal('editDeptModal')"><i data-lucide="pencil"></i></button><button class="btn btn-ghost btn-icon btn-sm" onclick="openModal('deleteDeptModal')"><i data-lucide="trash-2"></i></button></td></tr>
                <tr><td>8</td><td>Social Welfare</td><td>Dr. Liza Fernandez</td><td>14</td>
                    <td class="table-actions"><button class="btn btn-ghost btn-icon btn-sm" onclick="openModal('editDeptModal')"><i data-lucide="pencil"></i></button><button class="btn btn-ghost btn-icon btn-sm" onclick="openModal('deleteDeptModal')"><i data-lucide="trash-2"></i></button></td></tr>
                <tr><td>9</td><td>Planning & Development</td><td>Arch. Nina Torres</td><td>9</td>
                    <td class="table-actions"><button class="btn btn-ghost btn-icon btn-sm" onclick="openModal('editDeptModal')"><i data-lucide="pencil"></i></button><button class="btn btn-ghost btn-icon btn-sm" onclick="openModal('deleteDeptModal')"><i data-lucide="trash-2"></i></button></td></tr>
                <tr><td>10</td><td>Treasurer's Office</td><td>CPA Roberto Garcia</td><td>11</td>
                    <td class="table-actions"><button class="btn btn-ghost btn-icon btn-sm" onclick="openModal('editDeptModal')"><i data-lucide="pencil"></i></button><button class="btn btn-ghost btn-icon btn-sm" onclick="openModal('deleteDeptModal')"><i data-lucide="trash-2"></i></button></td></tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Create Dept Modal -->
<div class="modal-overlay" id="createDeptModal">
    <div class="modal">
        <div class="modal-header"><h3 class="modal-title">Add Department</h3><button class="modal-close" onclick="closeModal('createDeptModal')"><i data-lucide="x"></i></button></div>
        <div class="modal-body">
            <div class="form-group"><label class="form-label form-label-required">Department Name</label><input type="text" class="form-control" placeholder="e.g. City Health Office" /></div>
            <div class="form-group"><label class="form-label">Department Head</label><input type="text" class="form-control" placeholder="Name of department head" /></div>
            <div class="form-group"><label class="form-label">Personnel Count</label><input type="number" class="form-control" placeholder="0" /></div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeModal('createDeptModal')">Cancel</button>
            <button class="btn btn-primary" onclick="closeModal('createDeptModal'); showToast('Department created','success')"><i data-lucide="plus"></i> Create</button>
        </div>
    </div>
</div>

<!-- Edit Dept Modal -->
<div class="modal-overlay" id="editDeptModal">
    <div class="modal">
        <div class="modal-header"><h3 class="modal-title">Edit Department</h3><button class="modal-close" onclick="closeModal('editDeptModal')"><i data-lucide="x"></i></button></div>
        <div class="modal-body">
            <div class="form-group"><label class="form-label">Department Name</label><input type="text" class="form-control" value="HRMO" /></div>
            <div class="form-group"><label class="form-label">Department Head</label><input type="text" class="form-control" value="Dr. Ana Reyes" /></div>
            <div class="form-group"><label class="form-label">Personnel Count</label><input type="number" class="form-control" value="15" /></div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeModal('editDeptModal')">Cancel</button>
            <button class="btn btn-primary" onclick="closeModal('editDeptModal'); showToast('Department updated','success')"><i data-lucide="save"></i> Save</button>
        </div>
    </div>
</div>

<!-- Delete Dept Modal -->
<div class="modal-overlay" id="deleteDeptModal">
    <div class="modal">
        <div class="modal-header"><h3 class="modal-title">Delete Department</h3><button class="modal-close" onclick="closeModal('deleteDeptModal')"><i data-lucide="x"></i></button></div>
        <div class="modal-body"><p>Are you sure you want to delete this department? Documents linked to this department will need to be reassigned.</p></div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeModal('deleteDeptModal')">Cancel</button>
            <button class="btn btn-danger" onclick="closeModal('deleteDeptModal'); showToast('Department deleted','error')"><i data-lucide="trash-2"></i> Delete</button>
        </div>
    </div>
</div>
