@{
    ViewData["Title"] = "New Document";
}

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title">New Document</h1>
        <p class="page-subtitle">Register a new document and generate routing slip</p>
    </div>
    <div class="page-header-right">
        <a href="/Documents" class="btn btn-secondary">
            <i data-lucide="arrow-left"></i> Back to Documents
        </a>
    </div>
</div>

<form onsubmit="event.preventDefault(); showToast('Document TNG-2026-0014 created successfully! QR Code generated.','success'); setTimeout(function(){ window.location.href='/Documents'; }, 1500);">
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px;">
        <!-- LEFT: Document Information -->
        <div class="card">
            <div class="card-header">
                <span class="card-header-title">Document Information</span>
            </div>
            <div class="card-body">
                <div class="form-group">
                    <label class="form-label">Reference Number</label>
                    <input type="text" class="form-control" value="TNG-2026-0014" readonly style="background:#f8fafc;" />
                    <span class="form-hint">Auto-generated by the system</span>
                </div>

                <div class="form-group">
                    <label class="form-label form-label-required">Document Title</label>
                    <input type="text" class="form-control" placeholder="Enter document title / subject" required />
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label form-label-required">Document Type</label>
                        <select class="form-control" required>
                            <option value="">Select type...</option>
                            <option>Research Incentive</option>
                            <option>Travel Order</option>
                            <option>Leave Application</option>
                            <option>Memorandum</option>
                            <option>Purchase Request</option>
                            <option>Certificate</option>
                            <option>Special Order</option>
                            <option>Administrative Order</option>
                            <option>Memo Circular</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label form-label-required">ARTA Tier</label>
                        <select class="form-control" required>
                            <option value="">Select tier...</option>
                            <option>Simple (3 working days)</option>
                            <option>Complex (7 working days)</option>
                            <option>Highly Technical (20 working days)</option>
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label form-label-required">Submitting Department</label>
                        <select class="form-control" required>
                            <option value="">Select department...</option>
                            <option>HRMO</option>
                            <option>Mayor's Office</option>
                            <option>CDRRMO</option>
                            <option>Budget Office</option>
                            <option>GSO</option>
                            <option>Engineering</option>
                            <option>Social Welfare</option>
                            <option>Admin Division</option>
                            <option>Planning & Development</option>
                            <option>Treasurer's Office</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Date Filed</label>
                        <input type="date" class="form-control" value="2026-07-01" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Remarks</label>
                    <textarea class="form-control" rows="3" placeholder="Additional remarks or notes..."></textarea>
                </div>

                <div class="form-group">
                    <label class="form-label">Attachments</label>
                    <input type="file" class="form-control" multiple />
                    <span class="form-hint">Upload supporting documents (PDF, DOC, images)</span>
                </div>
            </div>
        </div>

        <!-- RIGHT: Routing Slip -->
        <div class="card">
            <div class="card-header">
                <span class="card-header-title">Routing Slip</span>
                <button type="button" class="btn btn-ghost btn-sm" onclick="printPage()">
                    <i data-lucide="printer"></i> Print
                </button>
            </div>
            <div class="card-body">
                <div class="routing-slip" id="routingSlipSection">
                    <div class="routing-slip-header">
                        <div class="routing-slip-title">ROUTING SLIP</div>
                        <div class="routing-slip-sub">Office of the Mayor — City of Mati, Davao Oriental</div>
                    </div>

                    <div class="routing-slip-grid">
                        <div class="routing-slip-field">
                            <label>Tracking No</label>
                            <span>TNG-2026-0014</span>
                        </div>
                        <div class="routing-slip-field">
                            <label>Date</label>
                            <span>July 1, 2026</span>
                        </div>
                        <div class="routing-slip-field">
                            <label>Classification</label>
                            <span>—</span>
                        </div>
                        <div class="routing-slip-field">
                            <label>Received By</label>
                            <input type="text" class="form-control" placeholder="Name of receiver" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label form-label-required">Forward To</label>
                        <select class="form-control">
                            <option value="">Select receiving department...</option>
                            <option>Office of the Mayor</option>
                            <option>City Administrator's Office</option>
                            <option>HRMO</option>
                            <option>Budget Office</option>
                            <option>Treasurer's Office</option>
                            <option>GSO</option>
                            <option>Engineering</option>
                            <option>Planning & Development</option>
                        </select>
                    </div>

                    <div class="routing-slip-instructions">
                        <h3>Instructions</h3>
                        <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px;">
                            <label class="form-check"><input type="checkbox" /> For Your Information (FYI)</label>
                            <label class="form-check"><input type="checkbox" /> For Approval</label>
                            <label class="form-check"><input type="checkbox" /> For Review</label>
                            <label class="form-check"><input type="checkbox" /> For Signature</label>
                            <label class="form-check"><input type="checkbox" /> For Filing</label>
                            <label class="form-check"><input type="checkbox" /> For Return</label>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Routing Remarks</label>
                        <textarea class="form-control" rows="2" placeholder="Special instructions or notes for routing..."></textarea>
                    </div>

                    <div class="routing-slip-signatories">
                        <div class="signatory-block">
                            <input type="text" class="form-control" placeholder="Name" style="text-align:center; margin-bottom:4px;" />
                            <div class="signatory-line">
                                <div class="signatory-role">Reviewer</div>
                            </div>
                        </div>
                        <div class="signatory-block">
                            <input type="text" class="form-control" placeholder="Name" style="text-align:center; margin-bottom:4px;" />
                            <div class="signatory-line">
                                <div class="signatory-role">Approver</div>
                            </div>
                        </div>
                        <div class="signatory-block">
                            <input type="text" class="form-control" placeholder="Name" style="text-align:center; margin-bottom:4px;" />
                            <div class="signatory-line">
                                <div class="signatory-role">Supervisor</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Submit Bar -->
    <div style="margin-top:20px; display:flex; justify-content:flex-end; gap:8px;">
        <a href="/Documents" class="btn btn-secondary">Cancel</a>
        <button type="submit" class="btn btn-primary">
            <i data-lucide="send"></i> Submit Document
        </button>
    </div>
</form>
