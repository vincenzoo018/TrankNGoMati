@model TrackNGoMati.Models.User
@{
    ViewData["Title"] = "My Profile & Settings";
    Layout = ViewBag.Layout;
}

<div class="page-header animate-fade-in" style="margin-bottom: 24px;">
    <h1 class="page-title">Profile & Settings</h1>
    <p class="page-subtitle">Manage your account, preferences, and out-of-office routing.</p>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success" style="padding:16px; background:#D1FAE5; color:#065F46; border-radius:8px; margin-bottom:24px;">
        @TempData["Success"]
    </div>
}

<div class="card animate-fade-in" style="max-width: 600px; padding: 24px;">
    <h2 style="font-size: 18px; margin-bottom: 16px;">Out-of-Office Routing</h2>
    <p style="font-size: 13px; color: var(--ink-muted); margin-bottom: 24px;">
        Enable this if you are on leave. Any documents routed to you will automatically be forwarded to your delegated user.
    </p>

    <form method="post" action="/Profile/UpdateOutOfOffice">
        <div class="form-group" style="margin-bottom: 16px;">
            <label class="form-label" style="display:flex; align-items:center; gap:8px;">
                <input type="checkbox" name="IsOutOfOffice" value="true" @(Model.IsOutOfOffice ? "checked" : "") onchange="document.getElementById('delegateWrapper').style.display = this.checked ? 'block' : 'none';" />
                <span style="font-weight:600;">I am currently Out of Office</span>
            </label>
        </div>

        <div class="form-group" id="delegateWrapper" style="display: @(Model.IsOutOfOffice ? "block" : "none"); margin-bottom: 24px;">
            <label class="form-label">Delegate User</label>
            <select class="form-control" name="DelegatedUserId">
                <option value="">-- Select a User to delegate to --</option>
                @foreach (var u in ViewBag.Users)
                {
                    if (Model.DelegatedUserId == u.Id) {
                        <option value="@u.Id" selected>@u.FullName (@u.Department)</option>
                    } else {
                        <option value="@u.Id">@u.FullName (@u.Department)</option>
                    }
                }
            </select>
        </div>

        <button type="submit" class="btn btn-primary"><i data-lucide="save"></i> Save Settings</button>
    </form>
</div>
