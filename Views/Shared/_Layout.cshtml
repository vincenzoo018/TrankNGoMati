@using TrackNGoMati.Services
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    var session = HttpContextAccessor.HttpContext?.Session;
    var currentRole = session?.GetInt32(SessionHelper.KEY_ROLE) ?? 0;
    var currentFullName = session?.GetString(SessionHelper.KEY_FULL_NAME) ?? "Guest";
    var currentDept = session?.GetString(SessionHelper.KEY_DEPT) ?? "";
    var currentPage = ViewBag.CurrentPage as string ?? "Dashboard";

    string roleName = currentRole switch
    {
        SessionHelper.ROLE_ADMIN => "Executive Admin",
        SessionHelper.ROLE_RECORDS => "Records Officer",
        SessionHelper.ROLE_DEPT => "Department Head",
        SessionHelper.ROLE_MAYOR => "Mayor",
        SessionHelper.ROLE_CART => "CART Officer",
        _ => "Guest"
    };
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — TrackNGo Mati</title>
    <meta name="description" content="EODB-Compliant Smart Document Tracking & Escalation System for the City Government of Mati" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <!-- ===== TOPBAR ===== -->
    <header class="topbar">
        <div style="display:flex; align-items:center; gap: 16px;">
            <a href="#" style="color:var(--white); text-decoration:none; font-size:12px;">Quick Links</a>
            <span style="color:rgba(255,255,255,0.5);">·</span>
            <a href="#" style="color:var(--white); text-decoration:none; font-size:12px;">Quality Assurance</a>
            <span style="color:rgba(255,255,255,0.5);">·</span>
            <a href="#" style="color:var(--white); text-decoration:none; font-size:12px;">Support</a>
        </div>
        <div style="margin-left:auto; display:flex; align-items:center; gap:12px;">
            <button class="topbar-btn" title="Notifications"><i data-lucide="bell"></i></button>
            <button class="topbar-btn" title="Favorites"><i data-lucide="star"></i></button>
            <button class="topbar-btn" title="Bookmarks"><i data-lucide="flag"></i></button>
            <button class="topbar-btn" title="Profile"><i data-lucide="user"></i></button>
            <button class="topbar-btn" title="Settings"><i data-lucide="settings"></i></button>
            <a href="/Account/Logout" class="topbar-btn" title="Logout">
                <i data-lucide="log-out"></i>
            </a>
        </div>
    </header>

    <!-- ===== SIDEBAR ===== -->
    <nav class="sidebar" id="sidebar">
        <div class="sidebar-logo">
            <div class="sidebar-logo-icon">T</div>
            <div class="sidebar-logo-text">
                <span class="sidebar-logo-title">TrackNGo Mati</span>
                <span class="sidebar-logo-sub">City of Mati</span>
            </div>
        </div>

        <div class="sidebar-role" id="current-role-label">@roleName</div>

        <div class="sidebar-nav">
            @{ var currentArea = ViewContext.RouteData.Values["area"]?.ToString() ?? "Admin"; }
            
            <a href="/@currentArea/Dashboard" class="sidebar-nav-item @(currentPage == "Dashboard" ? "active" : "")">
                <i data-lucide="layout-dashboard"></i> Dashboard
            </a>
            <a href="/Receiving/Document" class="sidebar-nav-item @(currentPage == "Document" ? "active" : "")">
                <i data-lucide="file-text"></i> All Documents
            </a>
            <a href="/DepartmentHead/Workflow" class="sidebar-nav-item @(currentPage == "Workflow" ? "active" : "")">
                <i data-lucide="git-branch"></i> Workflow Routing
            </a>
            <a href="#" class="sidebar-nav-item">
                <i data-lucide="qr-code"></i> QR Tracking
            </a>
            <a href="/Mayor/Signature" class="sidebar-nav-item @(currentPage == "Signature" ? "active" : "")">
                <i data-lucide="pen-tool"></i> Signatures & Audit
            </a>
            <a href="#" class="sidebar-nav-item">
                <i data-lucide="message-square"></i> SMS Notifications
            </a>
            <a href="/Cart/Reports" class="sidebar-nav-item @(currentPage == "Reports" ? "active" : "")">
                <i data-lucide="bar-chart-2"></i> Monitoring Reports
            </a>
            <a href="/Admin/UserManagement" class="sidebar-nav-item @(currentPage == "UserManagement" ? "active" : "")">
                <i data-lucide="users"></i> User Management
            </a>
            <a href="/Admin/Departments" class="sidebar-nav-item @(currentPage == "Departments" ? "active" : "")">
                <i data-lucide="building"></i> Departments
            </a>
            <a href="/Cart/ARTAEscalations" class="sidebar-nav-item @(currentPage == "ARTAEscalations" ? "active" : "")">
                <i data-lucide="shield-alert"></i> ARTA Escalation
            </a>
            <a href="/Cart/AuditTrail" class="sidebar-nav-item @(currentPage == "AuditTrail" ? "active" : "")">
                <i data-lucide="history"></i> Audit Logs & Trails
            </a>
        </div>

        <div class="sidebar-profile">
            <div class="profile-name">@currentFullName</div>
            <div class="profile-dept">@currentDept</div>
        </div>
    </nav>

    <!-- ===== MAIN CONTENT ===== -->
    <main class="main-content">
        @RenderBody()
    </main>

    <!-- ===== TOAST CONTAINER ===== -->
    <div id="toast-container" class="toast-container"></div>

    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <!-- Site JS -->
    <script src="~/js/site.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
