        </table>
    </div>
</div>

<!-- Resend Modal -->
<div class="modal-overlay" id="resendModal">
    <div class="modal">
        <div class="modal-header">
            <h3 class="modal-title">Resend SMS</h3>
            <button class="modal-close" onclick="closeModal('resendModal')"><i data-lucide="x"></i></button>
        </div>
        <div class="modal-body">
            <p>Are you sure you want to resend this SMS notification?</p>
            <p class="text-meta" style="margin-top:8px;">The message will be re-queued through the SMS gateway.</p>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeModal('resendModal')">Cancel</button>
            <button class="btn btn-primary" onclick="closeModal('resendModal'); showToast('SMS re-queued successfully','success')">
                <i data-lucide="send"></i> Resend
            </button>
        </div>
    </div>
</div>

<!-- Gateway Settings Modal -->
<div class="modal-overlay" id="smsGatewayModal">
    <div class="modal">
        <div class="modal-header">
            <h3 class="modal-title">SMS Gateway Settings</h3>
            <button class="modal-close" onclick="closeModal('smsGatewayModal')"><i data-lucide="x"></i></button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label class="form-label">Gateway Provider</label>
                <input type="text" class="form-control" value="Mock SMS Gateway (Demo)" readonly style="background:#f8fafc;" />
            </div>
            <div class="form-group">
                <label class="form-label">API Endpoint</label>
                <input type="text" class="form-control" value="https://api.mocksms.local/send" readonly style="background:#f8fafc;" />
            </div>
            <div class="form-group">
                <label class="form-label">Status</label>
                <span class="badge badge-completed">Connected</span>
            </div>
            <p class="text-meta" style="margin-top:8px;">This is a mock SMS gateway for demonstration. In production, configure with a real SMS provider.</p>
        </div>
        <div class="modal-footer">
            <button class="btn btn-primary" onclick="closeModal('smsGatewayModal')">Close</button>
        </div>
    </div>
</div>
