@{
    ViewData["Title"] = "SMS Notifications";
}

<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title">SMS Notifications</h1>
        <p class="page-subtitle">Monitor automated SMS alerts and manage the notification gateway</p>
    </div>
    <div class="page-header-right">
        <button class="btn btn-secondary" onclick="openModal('smsGatewayModal')">
            <i data-lucide="settings"></i> Gateway Settings
        </button>
    </div>
</div>

<div class="stat-grid">
    <div class="stat-card">
        <div class="stat-card-icon brand"><i data-lucide="message-square"></i></div>
        <div class="stat-card-info">
            <span class="stat-card-value">342</span>
            <span class="stat-card-label">Total SMS Sent</span>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-card-icon brand"><i data-lucide="check-circle"></i></div>
        <div class="stat-card-info">
            <span class="stat-card-value">328</span>
            <span class="stat-card-label">Delivered</span>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-card-icon destructive"><i data-lucide="x-circle"></i></div>
        <div class="stat-card-info">
            <span class="stat-card-value">14</span>
            <span class="stat-card-label">Failed</span>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-card-icon brand"><i data-lucide="activity"></i></div>
        <div class="stat-card-info">
            <span class="stat-card-value">95.9%</span>
            <span class="stat-card-label">Success Rate</span>
        </div>
    </div>
</div>

<div class="filter-bar">
    <div class="search-input">
        <i data-lucide="search"></i>
        <input type="text" id="tableSearch" placeholder="Search by recipient, mobile, or reference..." />
    </div>
    <select class="filter-select">
        <option value="">All Statuses</option>
        <option>Sent</option>
        <option>Failed</option>
    </select>
</div>

