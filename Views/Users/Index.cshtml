@{
    ViewData["Title"] = "User Management";
}

<div class="page-header">
    <div class="page-header-left">
        <h1 class="page-title">User Management</h1>
        <p class="page-subtitle">Manage system user accounts, roles, and access permissions</p>
    </div>
    <div class="page-header-right">
        <button class="btn btn-primary" onclick="openModal('createUserModal')">
            <i data-lucide="user-plus"></i> Add User
        </button>
    </div>
</div>

<div class="filter-bar">
    <div class="search-input">
        <i data-lucide="search"></i>
        <input type="text" id="tableSearch" placeholder="Search users..." />
    </div>
    <select class="filter-select">
        <option value="">All Roles</option>
        <option>System Administrator</option>
        <option>Department Personnel</option>
        <option>Department Head</option>
        <option>Authorized Signatory</option>
        <option>Client</option>
    </select>
    <select class="filter-select">
        <option value="">All Status</option>
        <option>Active</option>
        <option>Inactive</option>
    </select>
</div>

