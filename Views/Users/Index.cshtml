                        <button class="btn btn-ghost btn-icon btn-sm" onclick="openModal('deleteUserModal')"><i data-lucide="trash-2"></i></button>
                    </td>
                </tr>
                <tr>
                    <td>Atty. Carlos Mendoza</td><td>c.mendoza@mati.gov.ph</td><td>Authorized Signatory</td><td>City Admin</td><td>0919-345-6789</td>
